---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Nueva Contraseña | Ágatha Gatos Persas"
    description="Restablece tu contraseña de forma segura."
>
    <main class="min-h-screen bg-[#FAF9F6] flex items-center justify-center pt-24 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-purple-100 rounded-full blur-3xl opacity-50 translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#FF6B6B]/10 rounded-full blur-3xl opacity-50 -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

        <div class="max-w-md w-full relative z-10 bg-white p-10 rounded-[3rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-pink-50 transition-all duration-500 hover:shadow-2xl">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-purple-50 text-purple-600 mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h2 class="text-3xl font-black text-[#2E2E2E] mb-2">Nueva Contraseña</h2>
                <p class="text-gray-500">Introduce tu nueva contraseña para acceder a tu cuenta.</p>
            </div>

            <div id="auth-alert" class="hidden mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300"></div>

            <form id="reset-password-form" class="space-y-6">
                <div>
                    <label for="password" class="block text-sm font-bold text-gray-700 mb-2">Nueva Contraseña</label>
                    <input type="password" id="password" required minlength="6" class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all duration-300 text-black" placeholder="••••••••" />
                </div>

                <div>
                    <label for="confirm-password" class="block text-sm font-bold text-gray-700 mb-2">Confirmar Contraseña</label>
                    <input type="password" id="confirm-password" required minlength="6" class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all duration-300 text-black" placeholder="••••••••" />
                </div>

                <button type="submit" id="submit-btn" class="w-full bg-[#FF6B6B] hover:bg-[#e65c5c] text-white font-bold py-3.5 px-6 rounded-2xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 flex justify-center items-center gap-2">
                    <span>Cambiar Contraseña</span>
                    <span id="spinner" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                </button>
            </form>
        </div>
    </main>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    const form = document.getElementById("reset-password-form") as HTMLFormElement;
    const alertBox = document.getElementById("auth-alert");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const spinner = document.getElementById("spinner");
    const btnText = submitBtn.querySelector("span");

    const showAlert = (message: string, isError: boolean = true) => {
        if (!alertBox) return;
        alertBox.textContent = message;
        alertBox.className = `mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300 block ${isError ? "bg-red-50 text-red-600 border border-red-100" : "bg-green-50 text-green-600 border border-green-100"}`;
    };

    const setLoading = (loading: boolean) => {
        submitBtn.disabled = loading;
        if (loading) {
            spinner?.classList.remove("hidden");
            if (btnText) btnText.textContent = "Actualizando...";
        } else {
            spinner?.classList.add("hidden");
            if (btnText) btnText.textContent = "Cambiar Contraseña";
        }
    };

    // Al llegar a esta página, Supabase debería habernos logueado vía el link del email
    const checkAuth = async () => {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
            showAlert("El enlace ha expirado o no es válido. Serás redirigido al login...");
            setTimeout(() => {
                window.location.href = "/login";
            }, 3000);
        }
    };

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const password = (document.getElementById("password") as HTMLInputElement).value;
        const confirmPassword = (document.getElementById("confirm-password") as HTMLInputElement).value;

        if (password !== confirmPassword) {
            showAlert("Las contraseñas no coinciden.");
            return;
        }

        setLoading(true);
        if (alertBox) alertBox.classList.add("hidden");

        try {
            const { error } = await supabase.auth.updateUser({ password });

            if (error) throw error;

            showAlert("¡Contraseña actualizada con éxito! Redirigiendo...", false);
            setTimeout(() => {
                window.location.href = "/profile";
            }, 2000);
        } catch (error: any) {
            showAlert(error.message || "Error al actualizar la contraseña");
        } finally {
            setLoading(false);
        }
    });

    checkAuth();
</script>
