---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Panel de Administración | Ágatha Gatos Persas"
    description="Gestión de usuarios y plataforma."
>
    <main class="min-h-screen bg-[#FAF9F6] pt-32 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <!-- Decoración -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-purple-100 rounded-full blur-3xl opacity-50 translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
        
        <div class="max-w-6xl mx-auto relative z-10">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                <div>
                    <h1 class="text-4xl font-black text-[#2E2E2E] mb-2">Panel de Control</h1>
                    <p class="text-gray-500 font-medium">Gestiona los usuarios y permisos de la plataforma</p>
                </div>
                <a href="/profile" class="bg-white text-gray-700 font-bold py-2.5 px-6 rounded-2xl shadow-sm border border-gray-100 hover:bg-gray-50 transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Volver al Perfil
                </a>
            </div>

            <!-- Dashboard Stats -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Total Usuarios</p>
                    <p id="stat-total-users" class="text-3xl font-black text-[#FF6B6B]">...</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Administradores</p>
                    <p id="stat-admins" class="text-3xl font-black text-purple-600">...</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Cuentas Nuevas (Mes)</p>
                    <p id="stat-new-users" class="text-3xl font-black text-blue-500">...</p>
                </div>
            </div>

            <!-- Users Table -->
            <div class="bg-white rounded-[3rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 overflow-hidden">
                <div class="p-8 border-b border-gray-50 bg-gray-50/50 flex justify-between items-center">
                    <h2 class="text-xl font-black text-[#2E2E2E]">Usuarios Registrados</h2>
                    <div class="relative">
                        <input type="text" id="user-search" placeholder="Buscar por nombre o email..." class="pl-10 pr-4 py-2 rounded-xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all text-sm w-64 text-gray-900 placeholder:text-gray-400" />
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-50">
                                <th class="px-8 py-4">Usuario</th>
                                <th class="px-8 py-4">Email / Teléfono</th>
                                <th class="px-8 py-4">Rol</th>
                                <th class="px-8 py-4">Registro</th>
                                <th class="px-8 py-4 text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="users-tbody" class="divide-y divide-gray-50">
                            <!-- Los usuarios se cargarán aquí -->
                            <tr>
                                <td colspan="5" class="px-8 py-12 text-center text-gray-400 italic">
                                    Cargando usuarios...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal de Confirmación de Borrado -->
    <div id="delete-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="close-delete-modal-bg"></div>
        <div class="bg-white rounded-[2.5rem] p-8 max-w-sm w-full relative z-10 animate-fade-in-up text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-xl font-black text-[#2E2E2E] mb-2">¿Eliminar usuario?</h3>
            <p class="text-gray-500 text-sm mb-6">Esta acción no se puede deshacer. Se eliminará el perfil del usuario de la base de datos.</p>
            <div class="flex gap-3">
                <button id="cancel-delete" class="flex-1 bg-gray-100 text-gray-700 font-bold py-3 rounded-2xl hover:bg-gray-200 transition-all">Cancelar</button>
                <button id="confirm-delete" class="flex-1 bg-red-500 text-white font-bold py-3 rounded-2xl hover:bg-red-600 transition-all shadow-lg shadow-red-100">Eliminar</button>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    let allUsers: any[] = [];
    let userToDelete: string | null = null;

    const initAdmin = async () => {
        const { data: { session } } = await supabase.auth.getSession();
        
        if (!session) {
            window.location.href = "/login";
            return;
        }

        // Verificar si es admin
        const { data: profile } = await supabase
            .from('profiles')
            .select('role')
            .eq('id', session.user.id)
            .single();

        if (!profile || profile.role !== 'admin') {
            window.location.href = "/";
            return;
        }

        await loadUsers();
        setupEventListeners();
    };

    const loadUsers = async () => {
        const { data: profiles, error } = await supabase
            .from('profiles')
            .select('*')
            .order('updated_at', { ascending: false });

        if (error) {
            console.error("Error cargando usuarios:", error);
            // Si incluso updated_at falla, intentamos sin orden
            if (error.code === '42703') {
                const { data: retry } = await supabase.from('profiles').select('*');
                allUsers = retry || [];
            }
            return;
        }

        allUsers = profiles || [];
        renderUsers(allUsers);
        updateStats(allUsers);
    };

    const updateStats = (users: any[]) => {
        const total = users.length;
        const admins = users.filter(u => u.role === 'admin').length;
        const now = new Date();
        const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        // Usamos updated_at como aproximación si created_at no existe
        const news = users.filter(u => {
            const date = u.created_at || u.updated_at;
            return date && new Date(date) >= firstOfMonth;
        }).length;

        document.getElementById('stat-total-users')!.textContent = total.toString();
        document.getElementById('stat-admins')!.textContent = admins.toString();
        document.getElementById('stat-new-users')!.textContent = news.toString();
    };

    const renderUsers = (users: any[]) => {
        const tbody = document.getElementById('users-tbody');
        if (!tbody) return;

        if (users.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-12 text-center text-gray-400 italic">No se encontraron usuarios.</td></tr>`;
            return;
        }

        tbody.innerHTML = users.map(user => `
            <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-8 py-4">
                    <div class="flex items-center gap-3">
                        <img src="${user.avatar_url || 'https://api.dicebear.com/7.x/notionists/svg?seed=' + user.full_name}" class="w-10 h-10 rounded-xl bg-pink-50 object-cover" />
                        <div>
                            <p class="font-bold text-[#2E2E2E] line-clamp-1">${user.full_name}</p>
                            <p class="text-xs text-gray-400 font-medium">${user.id.slice(0, 8)}...</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-4">
                    <p class="text-sm font-bold text-[#2E2E2E]">${user.email || '—'}</p>
                    <p class="text-xs text-gray-400 font-medium">${user.phone || 'Sin tel.'}</p>
                </td>
                <td class="px-8 py-4">
                    <select class="role-selector bg-white border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-black transition-all focus:ring-2 focus:ring-purple-100 outline-none text-gray-900 cursor-pointer hover:border-purple-200" data-id="${user.id}">
                        <option value="user" ${user.role === 'user' ? 'selected' : ''}>Usuario</option>
                        <option value="admin" ${user.role === 'admin' ? 'selected' : ''}>Admin 🛡️</option>
                    </select>
                </td>
                <td class="px-8 py-4">
                    <p class="text-xs font-medium text-gray-500">
                        ${(user.created_at || user.updated_at) 
                            ? new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(user.created_at || user.updated_at))
                            : '—'}
                    </p>
                </td>
                <td class="px-8 py-4 text-right">
                    <button class="delete-user-btn p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all" data-id="${user.id}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                </td>
            </tr>
        `).join('');

        // Toggles de rol
        document.querySelectorAll('.role-selector').forEach(select => {
            select.addEventListener('change', async (e) => {
                const target = e.target as HTMLSelectElement;
                const userId = target.dataset.id;
                const newRole = target.value;

                const { error } = await supabase
                    .from('profiles')
                    .update({ role: newRole })
                    .eq('id', userId);

                if (error) {
                    alert("Error al cambiar rol: " + error.message);
                    loadUsers(); // Revertir visualmente
                } else {
                    // Actualizar stats sin recargar todo si es posible, o recargar
                    loadUsers();
                }
            });
        });

        // Botones de borrar
        document.querySelectorAll('.delete-user-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                userToDelete = (btn as HTMLElement).dataset.id || null;
                document.getElementById('delete-modal')?.classList.remove('hidden');
            });
        });
    };

    const setupEventListeners = () => {
        // Buscador
        document.getElementById('user-search')?.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase();
            const filtered = allUsers.filter(u => 
                u.full_name?.toLowerCase().includes(query) || 
                u.email?.toLowerCase().includes(query)
            );
            renderUsers(filtered);
        });

        // Modal de borrado
        document.getElementById('cancel-delete')?.addEventListener('click', () => {
            document.getElementById('delete-modal')?.classList.add('hidden');
            userToDelete = null;
        });

        document.getElementById('close-delete-modal-bg')?.addEventListener('click', () => {
            document.getElementById('delete-modal')?.classList.add('hidden');
            userToDelete = null;
        });

        document.getElementById('confirm-delete')?.addEventListener('click', async () => {
            if (!userToDelete) return;

            const { error } = await supabase
                .from('profiles')
                .delete()
                .eq('id', userToDelete);

            if (error) {
                alert("Error al eliminar perfil: " + error.message);
            } else {
                await loadUsers();
            }

            document.getElementById('delete-modal')?.classList.add('hidden');
            userToDelete = null;
        });
    };

    initAdmin();
</script>

<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
