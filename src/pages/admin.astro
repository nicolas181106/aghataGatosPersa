---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Panel de Administración | Ágatha Gatos Persas"
    description="Gestión de usuarios y plataforma."
>
    <main class="min-h-screen bg-[#FAF9F6] pt-32 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <!-- Decoración -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-purple-100 rounded-full blur-3xl opacity-50 translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
        
        <div class="max-w-6xl mx-auto relative z-10">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                <div>
                    <h1 class="text-4xl font-black text-[#2E2E2E] mb-2">Panel de Control</h1>
                    <p class="text-gray-500 font-medium">Gestiona los usuarios y permisos de la plataforma</p>
                </div>
                <a href="/profile" class="bg-white text-gray-700 font-bold py-2.5 px-6 rounded-2xl shadow-sm border border-gray-100 hover:bg-gray-50 transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Volver al Perfil
                </a>
            </div>

            <!-- Dashboard Stats -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Total Usuarios</p>
                    <p id="stat-total-users" class="text-3xl font-black text-[#FF6B6B]">...</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Administradores</p>
                    <p id="stat-admins" class="text-3xl font-black text-purple-600">...</p>
                </div>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-pink-50">
                    <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Cuentas Nuevas (Mes)</p>
                    <p id="stat-new-users" class="text-3xl font-black text-blue-500">...</p>
                </div>
            </div>

            <!-- Users Table -->
            <div class="bg-white rounded-[3rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] border border-gray-100 overflow-hidden">
                <div class="p-8 border-b border-gray-50 bg-gray-50/50 flex justify-between items-center">
                    <h2 class="text-xl font-black text-[#2E2E2E]">Usuarios Registrados</h2>
                    <div class="relative">
                        <input type="text" id="user-search" placeholder="Buscar por nombre o email..." class="pl-10 pr-4 py-2 rounded-xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all text-sm w-64 text-gray-900 placeholder:text-gray-400" />
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-50">
                                <th class="px-8 py-4">Usuario</th>
                                <th class="px-8 py-4">Email / Teléfono</th>
                                <th class="px-8 py-4">Rol</th>
                                <th class="px-8 py-4">Favoritos</th>
                                <th class="px-8 py-4 text-right">Acceso</th>
                            </tr>
                        </thead>
                        <tbody id="users-tbody" class="divide-y divide-gray-50">
                            <!-- Los usuarios se cargarán aquí -->
                            <tr>
                                <td colspan="5" class="px-8 py-12 text-center text-gray-400 italic">
                                    Cargando usuarios...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal de Confirmación de Baneo -->
    <div id="ban-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="close-ban-modal-bg"></div>
        <div class="bg-white rounded-[2.5rem] p-8 max-w-sm w-full relative z-10 animate-fade-in-up text-center">
            <div id="ban-modal-icon" class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <h3 id="ban-modal-title" class="text-xl font-black text-[#2E2E2E] mb-2">¿Bloquear usuario?</h3>
            <p id="ban-modal-text" class="text-gray-500 text-sm mb-6">El usuario no podrá acceder a su perfil ni realizar acciones en la plataforma.</p>
            <div class="flex gap-3">
                <button id="cancel-ban" class="flex-1 bg-gray-100 text-gray-700 font-bold py-3 rounded-2xl hover:bg-gray-200 transition-all">Cancelar</button>
                <button id="confirm-ban" class="flex-1 bg-red-500 text-white font-bold py-3 rounded-2xl hover:bg-red-600 transition-all shadow-lg shadow-red-100">Confirmar</button>
            </div>
        </div>
    </div>

    <!-- Modal de Detalles de Favoritos -->
    <div id="fav-modal" class="fixed inset-0 z-[110] hidden flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="close-fav-modal-bg"></div>
        <div class="bg-white rounded-[2.5rem] p-8 max-w-lg w-full relative z-10 animate-fade-in-up">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-black text-[#2E2E2E]">Favoritos de <span id="fav-modal-user-name" class="text-[#FF6B6B]">...</span></h3>
                <button id="close-fav-modal" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div id="fav-modal-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-4 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar contents-center">
                <!-- Se llenará dinámicamente -->
            </div>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    let allUsers: any[] = [];
    let userToDelete: string | null = null;

    const initAdmin = async () => {
        const { data: { session } } = await supabase.auth.getSession();
        
        if (!session) {
            window.location.href = "/login";
            return;
        }

        // Verificar si es admin
        const { data: profile } = await supabase
            .from('profiles')
            .select('role')
            .eq('id', session.user.id)
            .single();

        if (!profile || profile.role !== 'admin') {
            window.location.href = "/";
            return;
        }

        await loadUsers();
        setupEventListeners();
    };

    const loadUsers = async () => {
        const { data: profiles, error } = await supabase
            .from('profiles')
            .select('*')
            .order('updated_at', { ascending: false });

        if (error) {
            console.error("Error cargando usuarios:", error);
            // Si incluso updated_at falla, intentamos sin orden
            if (error.code === '42703') {
                const { data: retry } = await supabase.from('profiles').select('*');
                allUsers = retry || [];
            }
            return;
        }

        allUsers = profiles || [];

        // Traer favoritos de todos para estadísticas
        const { data: favorites } = await supabase.from('favorites').select('*');
        allFavorites = favorites || [];

        renderUsers(allUsers);
        updateStats(allUsers);
    };

    const updateStats = (users: any[]) => {
        const total = users.length;
        const admins = users.filter(u => u.role === 'admin').length;
        const now = new Date();
        const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
        // Usamos updated_at como aproximación si created_at no existe
        const news = users.filter(u => {
            const date = u.created_at || u.updated_at;
            return date && new Date(date) >= firstOfMonth;
        }).length;

        document.getElementById('stat-total-users')!.textContent = total.toString();
        document.getElementById('stat-admins')!.textContent = admins.toString();
        document.getElementById('stat-new-users')!.textContent = news.toString();
    };

    const renderUsers = (users: any[]) => {
        const tbody = document.getElementById('users-tbody');
        if (!tbody) return;

        if (users.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="px-8 py-12 text-center text-gray-400 italic">No se encontraron usuarios.</td></tr>`;
            return;
        }

        tbody.innerHTML = users.map(user => {
            const userFavs = allFavorites.filter(f => f.user_id === user.id);
            
            return `
            <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-8 py-4">
                    <div class="flex items-center gap-3">
                        <img src="${user.avatar_url || 'https://api.dicebear.com/7.x/notionists/svg?seed=' + user.full_name}" class="w-10 h-10 rounded-xl bg-pink-50 object-cover" />
                        <div>
                            <p class="font-bold text-[#2E2E2E] line-clamp-1">${user.full_name}</p>
                            <p class="text-xs text-gray-400 font-medium">${user.id.slice(0, 8)}...</p>
                        </div>
                    </div>
                </td>
                <td class="px-8 py-4">
                    <p class="text-sm font-bold text-[#2E2E2E]">${user.email || '—'}</p>
                    <p class="text-xs text-gray-400 font-medium">${user.phone || 'Sin tel.'}</p>
                </td>
                <td class="px-8 py-4">
                    <select class="role-selector bg-white border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-black transition-all focus:ring-2 focus:ring-purple-100 outline-none text-gray-900 cursor-pointer hover:border-purple-200" data-id="${user.id}">
                        <option value="user" ${user.role === 'user' ? 'selected' : ''}>Usuario</option>
                        <option value="admin" ${user.role === 'admin' ? 'selected' : ''}>Admin 🛡️</option>
                    </select>
                </td>
                <td class="px-8 py-4">
                    <button class="view-favs-btn flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-50 text-[#FF6B6B] hover:bg-red-100 transition-all border border-red-100" 
                            data-id="${user.id}" data-name="${user.full_name}">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                        <span class="font-bold text-xs">${userFavs.length}</span>
                    </button>
                </td>
                <td class="px-8 py-4 text-right">
                    <button class="ban-user-btn p-2 rounded-lg transition-all ${user.status === 'banned' ? 'text-red-500 bg-red-50 border border-red-100 hover:bg-red-100' : 'text-gray-400 hover:text-red-500 hover:bg-red-50'}" 
                            data-id="${user.id}" 
                            data-status="${user.status || 'active'}"
                            title="${user.status === 'banned' ? 'Desbloquear' : 'Bloquear'}">
                        ${user.status === 'banned' 
                            ? `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>`
                            : `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>`}
                    </button>
                </td>
            </tr>
        `; }).join('');

        // Toggles de rol
        document.querySelectorAll('.role-selector').forEach(select => {
            select.addEventListener('change', async (e) => {
                const target = e.target as HTMLSelectElement;
                const userId = target.dataset.id;
                const newRole = target.value;

                const { error } = await supabase
                    .from('profiles')
                    .update({ role: newRole })
                    .eq('id', userId);

                if (error) {
                    alert("Error al cambiar rol: " + error.message);
                    loadUsers(); // Revertir visualmente
                } else {
                    // Actualizar stats sin recargar todo si es posible, o recargar
                    loadUsers();
                }
            });
        });

        // Botón ver favoritos
        document.querySelectorAll('.view-favs-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = btn as HTMLElement;
                const userId = target.dataset.id;
                const userName = target.dataset.name;
                const userFavs = allFavorites.filter(f => f.user_id === userId);
                
                openFavsModal(userName || "Usuario", userFavs);
            });
        });

        // Botones de banear
        document.querySelectorAll('.ban-user-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = btn as HTMLElement;
                userToBan = target.dataset.id || null;
                const currentStatus = target.dataset.status || 'active';
                
                const modalTitle = document.getElementById('ban-modal-title');
                const modalText = document.getElementById('ban-modal-text');
                const confirmBtn = document.getElementById('confirm-ban');
                const iconContainer = document.getElementById('ban-modal-icon');

                if (currentStatus === 'banned') {
                    modalTitle!.textContent = "¿Desbloquear usuario?";
                    modalText!.textContent = "El usuario recuperará el acceso total a su perfil y funciones de la web.";
                    confirmBtn!.textContent = "Desbloquear";
                    confirmBtn!.className = "flex-1 bg-green-500 text-white font-bold py-3 rounded-2xl hover:bg-green-600 transition-all shadow-lg shadow-green-100";
                    iconContainer!.className = "w-16 h-16 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4";
                    iconContainer!.innerHTML = `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path></svg>`;
                    newStatus = 'active';
                } else {
                    modalTitle!.textContent = "¿Bloquear usuario?";
                    modalText!.textContent = "El usuario no podrá acceder a su perfil ni realizar acciones en la plataforma.";
                    confirmBtn!.textContent = "Bloquear";
                    confirmBtn!.className = "flex-1 bg-red-500 text-white font-bold py-3 rounded-2xl hover:bg-red-600 transition-all shadow-lg shadow-red-100";
                    iconContainer!.className = "w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4";
                    iconContainer!.innerHTML = `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>`;
                    newStatus = 'banned';
                }

                document.getElementById('ban-modal')?.classList.remove('hidden');
            });
        });
    };

    let userToBan: string | null = null;
    let newStatus: string = 'active';
    let allFavorites: any[] = [];

    const openFavsModal = (name: string, favs: any[]) => {
        document.getElementById('fav-modal-user-name')!.textContent = name;
        const grid = document.getElementById('fav-modal-grid');
        if (!grid) return;

        if (favs.length === 0) {
            grid.innerHTML = `<div class="col-span-full py-10 text-center text-gray-400 italic">Este usuario no tiene favoritos aún.</div>`;
        } else {
            grid.innerHTML = favs.map(f => `
                <div class="bg-gray-50 p-2 rounded-2xl border border-gray-100 flex flex-col items-center">
                    <img src="${f.cat_img}" class="w-full aspect-square object-cover rounded-xl mb-2" />
                    <p class="text-[10px] font-black text-gray-700 uppercase tracking-tight text-center">${f.cat_name}</p>
                </div>
            `).join('');
        }

        document.getElementById('fav-modal')?.classList.remove('hidden');
    };

    const setupEventListeners = () => {
        // Buscador
        document.getElementById('user-search')?.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase();
            const filtered = allUsers.filter(u => 
                u.full_name?.toLowerCase().includes(query) || 
                u.email?.toLowerCase().includes(query)
            );
            renderUsers(filtered);
        });

        // Modal de baneo
        document.getElementById('cancel-ban')?.addEventListener('click', () => {
            document.getElementById('ban-modal')?.classList.add('hidden');
            userToBan = null;
        });

        document.getElementById('close-ban-modal-bg')?.addEventListener('click', () => {
            document.getElementById('ban-modal')?.classList.add('hidden');
            userToBan = null;
        });

        document.getElementById('confirm-ban')?.addEventListener('click', async () => {
            if (!userToBan) return;

            const { error } = await supabase
                .from('profiles')
                .update({ status: newStatus })
                .eq('id', userToBan);

            if (error) {
                alert("Error al actualizar estado: " + error.message);
            } else {
                await loadUsers();
            }

            document.getElementById('ban-modal')?.classList.add('hidden');
            userToBan = null;
        });

        // Modal de favoritos
        document.getElementById('close-fav-modal')?.addEventListener('click', () => {
            document.getElementById('fav-modal')?.classList.add('hidden');
        });

        document.getElementById('close-fav-modal-bg')?.addEventListener('click', () => {
            document.getElementById('fav-modal')?.classList.add('hidden');
        });
    };

    initAdmin();
</script>

<style>
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
