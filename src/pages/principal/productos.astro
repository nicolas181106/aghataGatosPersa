---
import Layout from "@/layouts/Layout.astro";
import imgRascador from "@/assets/img/productos/rascador.jpg";
import imgJuguete from "@/assets/img/productos/juguete.jpg";
import imgComedero from "@/assets/img/productos/comedero.jpg";
import imgCama from "@/assets/img/productos/cama.jpg";
import imgArena from "@/assets/img/productos/arenero.jpg";

const categorias = [
  {
    slug: "rascadores",
    img: imgRascador.src,
    alt: "Rascador para gato persa en el salón de casa",
    titulo: "Rascadores para gatos persas",
    descripcion:
      "Protege tus muebles y ofrece a tu gato un lugar seguro donde estirarse, afilarse las uñas y liberar estrés.",
    etiqueta: "Cuidado de uñas",
    destacado: "Ideal para gatos de interior",
  },
  {
    slug: "juguetes",
    img: imgJuguete.src,
    alt: "Juguetes para gatos persas sobre el suelo",
    titulo: "Juguetes para mantenerlos activos",
    descripcion:
      "Pelotas, cañas, túneles y juguetes con hierba gatera para estimular cuerpo y mente sin agobiarles.",
    etiqueta: "Juego y actividad",
    destacado: "Perfecto para sesiones de 10–15 minutos",
  },
  {
    slug: "comida",
    img: imgComedero.src,
    alt: "Comedero y accesorios de alimentación para gatos persas",
    titulo: "Comida y accesorios de alimentación",
    descripcion:
      "Piensos, latas y comederos adaptados a gatos de cara chata para una alimentación cómoda y segura.",
    etiqueta: "Alimentación",
    destacado: "Opciones para estómagos sensibles",
  },
  {
    slug: "camas",
    img: imgCama.src,
    alt: "Cama cómoda para gato persa",
    titulo: "Camas cómodas y acogedoras",
    descripcion:
      "Camas mullidas, cuevas y mantas suaves para sus largas siestas en los lugares que más le gustan.",
    etiqueta: "Descanso",
    destacado: "Pensado para gatos muy tranquilos",
  },
  {
    slug: "areneros",
    img: imgArena.src,
    alt: "Arenero higiénico para gatos persas",
    titulo: "Areneros y accesorios de higiene",
    descripcion:
      "Areneros cerrados y accesorios para mantener la higiene diaria de forma discreta y fácil de limpiar.",
    etiqueta: "Higiene",
    destacado: "Mejora el olor y la limpieza del hogar",
  },
];
---

<Layout
  title="Productos para Gatos | Ágatha Gatos Persas"
  description="Productos y accesorios recomendados para gatos persa: rascadores, juguetes, comederos, camas y areneros."
  keywords="productos gatos persa, rascadores gatos persa, juguetes gatos persa, comederos gatos persa, camas gatos persa, areneros gatos persa, producto para gatos"
>
  <main class="bg-[#FDFCFB]/80 min-h-screen pb-20">
    <!-- Fondo Animado con Blobs -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-[-1]">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-pink-200/30 rounded-full blur-[100px] animate-blob"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[35%] h-[35%] bg-amber-100/40 rounded-full blur-[100px] animate-blob animation-delay-2000"></div>
      <div class="absolute top-[40%] right-[10%] w-[25%] h-[25%] bg-blue-50/30 rounded-full blur-[80px] animate-blob animation-delay-4000"></div>
    </div>

    <header class="pt-32 pb-10">
      <div class="max-w-7xl mx-auto px-6 sm:px-10">
        <div
          class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-[#FF6B6B] via-[#FF8E8E] to-amber-200 p-8 sm:p-16 shadow-2xl"
        >
          <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
              <nav class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-white/80 mb-4">
                <a href="/" class="hover:text-white transition-colors">Inicio</a>
                <span class="text-white/40">/</span>
                <span class="text-white">Productos</span>
              </nav>
              
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight tracking-tight">
                El Paraíso del <br />
                <span class="text-white/90">Gato Persa</span>
              </h1>
              <p class="text-lg text-white/90 font-medium leading-relaxed max-w-lg">
                Seleccionamos solo lo mejor: <strong>accesorios premium</strong> diseñados para la comodidad, salud y bienestar de los gatos más exigentes.
              </p>

              <div class="flex flex-wrap gap-4 pt-2">
                <div class="flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-md rounded-full text-white text-xs font-bold border border-white/30">
                  <span class="w-2 h-2 rounded-full bg-emerald-300 animate-pulse"></span>
                  Selección Premium
                </div>
                <div class="flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-md rounded-full text-white text-xs font-bold border border-white/30">
                  <span>⭐</span> Calidad Amazon Choice
                </div>
              </div>
            </div>

            <div class="hidden lg:flex justify-end">
              <div
                class="w-72 h-72 rounded-[3rem] bg-white/10 backdrop-blur-xl border border-white/30 rotate-12 flex items-center justify-center shadow-2xl relative group transition-all duration-700 hover:rotate-6"
              >
                <div
                  class="w-48 h-48 bg-white rounded-[2rem] shadow-inner flex flex-col items-center justify-center p-6 text-center transform -rotate-6 transition-transform group-hover:rotate-0"
                >
                  <span class="text-5xl mb-4">🐾</span>
                  <p class="text-sm font-bold text-gray-800 tracking-tighter">
                    PRODUCTOS <br />
                    <span class="text-[#FF6B6B]">TOP VENTAS</span>
                  </p>
                </div>
                <div
                  class="absolute -top-4 -left-4 w-12 h-12 bg-amber-300 rounded-full flex items-center justify-center animate-bounce shadow-lg"
                >
                  ✨
                </div>
              </div>
            </div>
          </div>

          <!-- Elemento decorativo de fondo -->
          <div
            class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl"
          >
          </div>
        </div>
      </div>
    </header>

    <!-- Grilla de Categorías -->
    <section class="max-w-7xl mx-auto px-6 sm:px-10 mt-12 mb-20 relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        {categorias.map((cat, index) => (
          <a
            href={`/productos/${cat.slug}`}
            class="group relative bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-[0_30px_60px_-12px_rgba(255,107,107,0.25)] border border-[#FFE2E2]/60 hover:border-[#FF6B6B]/40 transition-all duration-500 hover:-translate-y-3 flex flex-col"
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Imagen con Overlay -->
            <div class="relative h-64 sm:h-72 overflow-hidden">
              <img
                src={cat.img}
                alt={cat.alt}
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500" />
              
              <!-- Icono Flotante -->
              <div class="absolute top-6 right-6 w-12 h-12 rounded-2xl bg-white/20 backdrop-blur-lg border border-white/30 flex items-center justify-center text-2xl shadow-xl transform group-hover:rotate-12 transition-transform duration-500">
                {cat.slug === 'rascadores' && "🐾"}
                {cat.slug === 'juguetes' && "🧶"}
                {cat.slug === 'comida' && "🍽️"}
                {cat.slug === 'camas' && "🛌"}
                {cat.slug === 'areneros' && "✨"}
              </div>

              <!-- Etiqueta Superior -->
              <div class="absolute top-6 left-6 flex flex-col gap-2">
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/80 backdrop-blur-md border border-white/20 text-black text-[10px] font-black uppercase tracking-widest leading-none">
                  {cat.etiqueta}
                </span>
              </div>

              <!-- Titulo sobre la imagen -->
              <div class="absolute bottom-6 left-8 right-8">
                <h3 class="text-2xl font-black text-white leading-tight mb-1 transform group-hover:translate-x-2 transition-transform duration-500">
                  {cat.titulo}
                </h3>
              </div>
            </div>

            <!-- Contenido Inferior -->
            <div class="p-8 flex flex-col flex-1 bg-white relative">
              <div class="w-12 h-1 bg-gradient-to-r from-[#FF6B6B] to-transparent mb-4 rounded-full"></div>
              <p class="text-gray-600 leading-relaxed text-[15px] mb-6 flex-1">
                {cat.descripcion}
              </p>
              
              <div class="flex items-center justify-between mt-auto">
                <div class="flex items-center gap-2 text-[#FF6B6B] text-xs font-black uppercase tracking-tighter">
                  <span class="w-8 h-[2px] bg-[#FF6B6B]"></span>
                  {cat.destacado}
                </div>
                
                <div class="w-10 h-10 rounded-full bg-[#FF6B6B]/10 flex items-center justify-center text-[#FF6B6B] group-hover:bg-[#FF6B6B] group-hover:text-white transition-all duration-500 transform group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Sección de Transparencia Premium -->
    <section class="max-w-4xl mx-auto px-6 mb-24">
      <div class="bg-gradient-to-br from-amber-50 to-orange-50/30 rounded-[40px] p-8 md:p-12 border border-amber-100 shadow-xl shadow-amber-200/10 text-center relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 text-amber-200/40 transform rotate-12 -translate-y-4 translate-x-4 opacity-50">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        </div>
        
        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-amber-200 text-amber-800 rounded-full text-[10px] font-black uppercase tracking-widest mb-6 border border-amber-300/30">
            Aviso de Transparencia
          </div>
          <h2 class="text-2xl md:text-3xl font-black text-amber-900 mb-6">Tu compra nos ayuda a seguir cuidándolos</h2>
          <p class="text-amber-800/80 leading-relaxed text-lg max-w-2xl mx-auto">
            Nuestras recomendaciones se basan exclusivamente en la calidad de los materiales para el bienestar de tu gato. Participamos en programas de afiliados que nos ayudan a cubrir los gastos del criadero sin coste extra para ti.
          </p>
        </div>
      </div>
    </section>
  </main>

  <style>
    @keyframes blob {
      0% { transform: scale(1) translate(0, 0); }
      33% { transform: scale(1.1) translate(30px, -50px); }
      66% { transform: scale(0.9) translate(-20px, 20px); }
      100% { transform: scale(1) translate(0, 0); }
    }
    .animate-blob {
      animation: blob 7s infinite linear;
    }
    .animation-delay-2000 {
      animation-delay: 2s;
    }
    .animation-delay-4000 {
      animation-delay: 4s;
    }
  </style>
</Layout>
