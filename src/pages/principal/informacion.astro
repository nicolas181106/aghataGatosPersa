---

<Layout
  title="Blog de cuidados del gato persa | Ágatha Gatos Persas"
  description="Artículos y guías sobre cuidados, salud, alimentación y comportamiento del gato persa."
>
  <main class="bg-[#FDFCFB] min-h-screen pb-20">
    <header class="pt-32 pb-10">
      <div class="max-w-6xl mx-auto px-4">
        <div
          class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-[#FF6B6B] via-[#FF8E8E] to-amber-200 p-8 sm:p-16 shadow-2xl"
        >
          <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
              <span
                class="inline-block px-4 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-xs font-bold text-white uppercase tracking-widest"
              >
                Información para Cuidadores
              </span>
              <h1
                class="text-4xl md:text-6xl font-black text-white leading-tight tracking-tight"
              >
                El Manual del <br />
                <span class="text-white/90">Gato Persa</span>
              </h1>
              <p
                class="text-lg text-white/90 font-medium leading-relaxed max-w-lg"
              >
                Explora nuestra selección de guías expertas diseñadas para
                brindarle a tu compañero felino la vida saludable y feliz que se
                merece.
              </p>
            </div>

            <div class="hidden lg:flex justify-end">
              <div
                class="w-72 h-72 rounded-[3rem] bg-white/10 backdrop-blur-xl border border-white/30 rotate-12 flex items-center justify-center shadow-2xl relative group transition-all duration-700 hover:rotate-6"
              >
                <div
                  class="w-48 h-48 bg-white rounded-[2rem] shadow-inner flex flex-col items-center justify-center p-6 text-center transform -rotate-6 transition-transform group-hover:rotate-0"
                >
                  <span class="text-5xl mb-4">📖</span>
                  <p class="text-sm font-bold text-gray-800 tracking-tighter">
                    CONTENIDO <br />
                    <span class="text-[#FF6B6B]">EXCLUSIVO</span>
                  </p>
                </div>
                <div
                  class="absolute -top-4 -left-4 w-12 h-12 bg-amber-300 rounded-full flex items-center justify-center animate-bounce shadow-lg"
                >
                  ✨
                </div>
              </div>
            </div>
          </div>

          <div
            class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl"
          >
          </div>
        </div>
      </div>
    </header>

    <section class="max-w-6xl mx-auto px-4 py-12">
      <div class="mb-12">
        <h2
          class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight"
        >
          Últimas Publicaciones
        </h2>
        <div class="h-1.5 w-20 bg-[#FF6B6B] mt-4 rounded-full"></div>
      </div>

      <div class="mb-16 max-w-2xl mx-auto">
        <div class="relative group">
          <input
            type="text"
            id="search-input"
            placeholder="¿Qué estás buscando? (ej: alimentación, salud, juegos...)"
            class="w-full bg-white border-2 border-gray-100 rounded-[2rem] py-5 pl-16 pr-6 text-lg text-gray-800 focus:ring-4 focus:ring-[#FF6B6B]/10 focus:border-[#FF6B6B] outline-none transition-all shadow-md hover:border-gray-200"
          />
          <span
            class="absolute left-6 top-1/2 -translate-y-1/2 text-3xl group-focus-within:scale-110 transition-transform"
            >🔍</span
          >
        </div>
      </div>

      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3" id="articles-grid">
        {
          articles.map((article) => (
            <article
              class={`article-card group relative flex flex-col bg-white rounded-[2rem] border border-gray-100 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 overflow-hidden ${article.featured ? "md:col-span-2 lg:col-span-2 flex-row" : ""}`}
              data-title={article.title.toLowerCase()}
              data-category={article.category.toLowerCase()}
              data-excerpt={article.excerpt.toLowerCase()}
            >
              <div
                class={`relative overflow-hidden ${article.featured ? "w-1/2 hidden md:block" : "h-64"}`}
              >
                <img
                  src={article.img.src}
                  alt={article.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60" />
                <span class="absolute top-6 left-6 bg-[#FF6B6B] text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest shadow-lg">
                  {article.category}
                </span>
              </div>

              <div class="p-8 flex flex-col flex-1 justify-between">
                <div>
                  <div class="flex items-center gap-3 text-xs font-bold text-gray-400 mb-4 uppercase tracking-tighter">
                    <span>
                      {new Date(article.date).toLocaleDateString("es-ES", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric",
                      })}
                    </span>
                    <span class="w-1.5 h-1.5 rounded-full bg-pink-200" />
                    <span>{article.readTime} lectura</span>
                  </div>

                  <h3
                    class={`font-black text-gray-900 group-hover:text-[#FF6B6B] transition-colors leading-tight mb-4 ${article.featured ? "text-3xl md:text-4xl" : "text-2xl"}`}
                  >
                    {article.title}
                  </h3>

                  <p class="text-gray-600 leading-relaxed text-sm md:text-base line-clamp-3">
                    {article.excerpt}
                  </p>
                </div>

                <div class="mt-8 flex items-center">
                  <a
                    href={`/informacion/${article.slug}`}
                    class="inline-flex items-center gap-2 text-sm font-black uppercase tracking-widest text-[#FF6B6B] group-hover:gap-4 transition-all"
                  >
                    Leer Guía Completa
                    <span class="text-xl">→</span>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  article {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>

<script is:inline>
  const searchInput = document.getElementById("search-input");
  const articleCards = document.querySelectorAll(".article-card");

  function filterArticles() {
    const query = searchInput.value.toLowerCase();

    articleCards.forEach((card) => {
      const title = card.dataset.title || "";
      const excerpt = card.dataset.excerpt || "";
      const category = card.dataset.category || "";

      const matchesSearch =
        title.includes(query) ||
        excerpt.includes(query) ||
        category.includes(query);

      if (matchesSearch) {
        card.style.display = "flex";
        // Reiniciar animación
        card.style.animation = "none";
        card.offsetHeight; // trigger reflow
        card.style.animation = "fadeInUp 0.6s ease-out forwards";
      } else {
        card.style.display = "none";
      }
    });

    // Mostrar mensaje si no hay resultados
    const grid = document.getElementById("articles-grid");
    let noResults = document.getElementById("no-results");
    const visibleCards = Array.from(articleCards).filter(
      (c) => c.style.display !== "none",
    );

    if (visibleCards.length === 0) {
      if (!noResults) {
        noResults = document.createElement("div");
        noResults.id = "no-results";
        noResults.className = "col-span-full py-20 text-center";
        noResults.innerHTML = `
          <p class="text-6xl mb-4">😿</p>
          <h3 class="text-2xl font-black text-gray-900 mb-2">No encontramos nada</h3>
          <p class="text-gray-500">Prueba con otra palabra clave</p>
        `;
        grid.appendChild(noResults);
      }
    } else if (noResults) {
      noResults.remove();
    }
  }

  searchInput.addEventListener("input", filterArticles);
</script>
