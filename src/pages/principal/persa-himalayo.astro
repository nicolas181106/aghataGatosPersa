---
import Layout from "../../layouts/layout.astro";
import oddie from "../../assets/img/oddie.jpg";
import cleo from "../../assets/img/cleo/cleo.jpeg";
import { gatosHimalayo } from "../../scripts/gatos-himalayo.js";
---

<Layout
	title="Gato persa himalayo | Ágatha Gatos Persas"
	description="Conoce al encantador Gato Persa Himalayo, una raza única con un pelaje impresionante y una personalidad cariñosa. Descubre más sobre esta maravillosa raza en nuestro criadero."
	keywords="gato persa himalayo, criadero de gatos persa, gatos persa en adopción"
>
	<main class="bg-white/90 text-[#2E2E2E] min-h-screen pb-10">
		<section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white py-20 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Gato Persa Himalayo</h1>
				<div class="w-32 h-1 bg-white mx-auto mb-4"></div>
				<p class="text-white text-lg max-w-2xl mx-auto">
					Conóce nuestros exclusivos gatos persas himalayos, una raza única con un pelaje impresionante y una personalidad cariñosa.
				</p>
			</div>
		</section>

		<section class="max-w-7xl mx-auto px-4 py-16">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-6">Nuestros Reproductores</h2>
				<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto"></div>
			</div>
			<div class="flex flex-col sm:flex-row gap-12 justify-center items-center">
				<figure class="bg-white p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 hover:cursor-pointer" id="oddieImg">
					<h3 class="text-2xl sm:text-3xl font-bold mb-4 text-[#FF6B6B]">Padre - Oddie</h3>
					<img src={oddie.src} alt="Padre gato persa europeo" loading="lazy" class="p-2 h-75 w-75 object-cover rounded-2xl bg-gradient-to-br from-[#FF6B6B] to-pink-400 shadow-lg"/>
				</figure>
				<figure class="bg-white p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 hover:cursor-pointer" id="blubeImg">
					<h3 class="text-2xl sm:text-3xl font-bold mb-4 text-[#FF6B6B]">Madre - Cleo</h3>
					<img src={cleo.src} alt="Madre gato persa europeo" loading="lazy" class="p-2 h-75 w-75 object-cover rounded-2xl bg-gradient-to-br from-[#FF6B6B] to-pink-400 shadow-lg"/>
				</figure>
			</div>
		</section>

		{gatosHimalayo.length === 0 && (
			<section class="bg-gradient-to-r from-gray-50 to-gray-100 py-20">
				<div class="max-w-4xl mx-auto px-4 text-center">
					<div class="text-6xl mb-6">😿</div>
					<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">¡Ups! No hay gatitos disponibles</h2>
					<p class="text-lg text-gray-700 mb-8 max-w-2xl mx-auto">
						Actualmente todos nuestros gatitos himalayos están adoptados, pero puedes explorar nuestras camadas anteriores o dejarnos tu correo para avisarte cuando tengamos nuevos gatitos.
					</p>
					<div class="flex flex-col sm:flex-row gap-6 justify-center">
						<a href="/principal/camadas-anteriores" 
						class="inline-block bg-[#FF6B6B] hover:bg-[#e65c5c] hover:-translate-y-1 text-white font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Ver camadas anteriores
						</a>
						<a href="/principal/contacto" 
						class="inline-block border-2 border-[#FF6B6B] text-[#FF6B6B] hover:bg-[#FF6B6B] hover:text-white hover:-translate-y-1 font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Avisarme cuando haya gatitos
						</a>
					</div>
				</div>
			</section>
		)}

		<section class="max-w-7xl mx-auto px-4 py-16 hidden">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-6">Gatitos Disponibles</h2>
				<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto"></div>
			</div>
			<div class="grid gap-12">
				{gatosHimalayo.map((gato) => (
					<article class="showImg px-4 flex flex-col md:flex-row justify-center items-center gap-12 bg-white p-8 rounded-3xl shadow-xl hover:shadow-2xl max-w-[900px] mx-auto transition-all duration-300 hover:-translate-y-2">
						<a
							href={`/gatos/${gato.slugHimalayo}`}
							class="relative block rounded-2xl shadow-lg overflow-hidden group transition-transform duration-300 hover:scale-105"
						>
							<img
								src={gato.imgSrc.src}
								alt={gato.alt}
								loading="lazy"
								class="p-2 h-75 w-75 object-cover rounded-2xl bg-gradient-to-br from-[#FF6B6B] to-pink-400"
							/>

							<span
								class="absolute inset-0 flex items-start justify-center 
									bg-black/70 text-white text-2xl font-bold pt-5
									opacity-0 group-hover:opacity-100
									transition-opacity duration-300 ease-in-out"
							>
								Ver más fotos
							</span>
						</a>
						<div class="flex flex-col text-left text-lg space-y-3">
							<p class="text-2xl font-bold text-[#FF6B6B]">{gato.nombre}</p>
							<p>
								<strong>Género:</strong> {gato.genero}
							</p>
							<p>
								<strong>Edad:</strong>{" "}
								<span
									class="edad-gatito"
									data-nacimiento={gato.edad.toISOString()}
								>
									Calculando...
								</span>
							</p>
							<div class="flex flex-col sm:flex-row gap-4 mt-6">
								<a
									href="/contacto"
									class="text-center inline-block hover:bg-[#FF6B6B] border-2 border-[#FF6B6B] text-[#FF6B6B] hover:text-white hover:-translate-y-1 font-semibold py-3 px-6 rounded-full transition-all duration-300 shadow-lg"
								>
									Adoptar gatito
								</a>
								<a
									href="/gatos-disponibles"
									class="text-center inline-block bg-[#FF6B6B] hover:bg-[#e65c5c] hover:-translate-y-1 text-white font-semibold py-3 px-6 rounded-full transition-all duration-300 shadow-lg"
								>
									Ver todos los gatos
								</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- Sección de Camadas Anteriores -->
		<section class="bg-gradient-to-br from-gray-50 to-pink-50 py-20">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">Camadas Anteriores</h2>
					<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto mb-6"></div>
					<p class="text-lg text-gray-700 max-w-2xl mx-auto">
						Mira algunos de nuestros gatitos himalayos de camadas anteriores para que te hagas una idea de cómo crecen nuestros bebés.
					</p>
				</div>
				
				{gatosHimalayo.length > 0 ? (
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
						{gatosHimalayo.map((gatoAnterior) => (
							<figure class="bg-white p-4 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 hover:scale-105 cursor-pointer">
								<img 
									src={gatoAnterior.img} 
									alt={gatoAnterior.alt}
									loading="lazy" 
									class="w-full h-48 object-cover rounded-xl mb-3 bg-gradient-to-br from-[#FF6B6B] to-pink-400 p-1"
								/>
								<figcaption class="text-center">
									<p class="font-bold text-[#2E2E2E] text-sm">{gatoAnterior.name}</p>
									<p class="text-xs text-gray-600">{gatoAnterior.gender}</p>
								</figcaption>
							</figure>
						))}
					</div>
				) : (
					<div class="bg-white/80 rounded-2xl shadow-lg p-8 text-center max-w-2xl mx-auto">
						<p class="text-gray-700 mb-4">Pronto agregaremos fotos de camadas anteriores de gatitos himalayos.</p>
						<p class="text-sm text-gray-600">Estamos trabajando en nuevas camadas de esta hermosa variedad.</p>
					</div>
				)}

				<div class="text-center mt-10">
					<a href="/principal/camadas-anteriores" 
						class="inline-block bg-[#FF6B6B] hover:bg-[#e65c5c] hover:-translate-y-1 text-white font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Ver todas las camadas anteriores
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
