---
import Layout from "../../layouts/Layout.astro";
import oddie from "../../assets/img/oddie.jpg";
import blube from "../../assets/img/blue/blube.jpg";
import ceres from "../../assets/img/ceres/ceres2.jpg";

import { gatosEuropeo } from "../../scripts/gatos-europeo anterior.js";
import { gatosChinchilla } from "../../scripts/gatos-chinchilla anterior.js";
import { gatosHimalayo } from "../../scripts/gatos-himalayo.js";
---

<Layout
  title="Camadas anteriores | Ágatha Gatos Persas"
  description="Descubre las camadas anteriores de gatos persas europeos, chinchilla e himalayos de nuestro criadero en Sevilla."
  keywords="camadas anteriores gato persa, criadero gatos persas Sevilla"
>
  <main class="min-h-screen bg-white text-[#2E2E2E] pt-20 pb-20">
    
    <section class="w-full bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white">
      <div class="max-w-6xl mx-auto px-4 py-12 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-white/80">
            Nuestra Historia · Transparencia y cariño
          </p>
          <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight">
            Camadas Anteriores
          </h1>
          <p class="max-w-xl text-sm md:text-base text-white/90 leading-relaxed">
            Cada gatito que ha pasado por <strong>Ágatha Gatos Persas</strong> es parte de nuestra familia. Aquí honramos su crecimiento y mostramos la calidad y salud de nuestras líneas de cría.
          </p>
        </div>
        
        <nav class="flex flex-col gap-3 bg-white/10 rounded-3xl p-6 border border-white/40 backdrop-blur-sm">
          <p class="font-semibold text-white text-lg">Explorar Variedades</p>
          <div class="flex flex-wrap gap-2">
            <a href="#europeo" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Europeo</a>
            <a href="#chinchilla" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Chinchilla</a>
            <a href="#himalayo" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Himalayo</a>
          </div>
        </nav>
      </div>
    </section>

    <section id="europeo" class="max-w-6xl mx-auto px-4 pt-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-[#FF6B6B]">Línea Persa Europeo</h2>
        <div class="w-24 h-1 bg-[#FF6B6B] mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="bg-orange-50 rounded-[3rem] p-8 md:p-12 mb-16 border border-orange-100 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          
          <div class="lg:w-1/3 w-full">
            <div class="mb-8">
              <span class="text-orange-500 font-bold text-sm uppercase tracking-widest">Camada Primavera</span>
              <h3 class="text-2xl font-bold text-gray-800 mt-2">26 de Mayo de 2025</h3>
              <p class="text-gray-600 mt-4 text-sm leading-relaxed">
                Una camada excepcional caracterizada por el temperamento equilibrado heredado de Bluey y el porte clásico de Oddie.
              </p>
            </div>

            <div class="space-y-4">
              <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-orange-100">
                <img src={oddie.src} class="w-44 h-44 rounded-full object-cover border-2 border-orange-500" alt="Padre Oddie" />
                <div>
                  <p class="text-[10px] text-orange-500 font-black uppercase">Padre</p>
                  <p class="font-bold text-gray-800">Oddie</p>
                </div>
              </div>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-orange-100">
                <img src={blube.src} class="w-44 h-44 rounded-full object-cover border-2 border-orange-500" alt="Madre Bluey" />
                <div>
                  <p class="text-[10px] text-orange-500 font-black uppercase">Madre</p>
                  <p class="font-bold text-gray-800">Bluey</p>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:w-2/3 w-full grid grid-cols-1 sm:grid-cols-2 gap-6">
            {gatosEuropeo.filter(gato => gato.birth === "26/05/2025").map((europeo) => (
              <article class="group bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-orange-200">
                <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                  <img src={europeo.img} alt={europeo.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="px-2 pb-2">
                  <h4 class="text-lg font-bold text-gray-800">{europeo.name}</h4>
                  <div class="flex justify-between items-center mt-1">
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">{europeo.gender}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="bg-blue-50/30 rounded-[3rem] p-8 md:p-12 mb-16 border border-blue-100 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          
          <div class="lg:w-1/3 w-full">
            <div class="mb-8">
              <span class="text-blue-500 font-bold text-sm uppercase tracking-widest">Camada Invierno</span>
              <h3 class="text-2xl font-bold text-gray-800 mt-2">02 de Diciembre de 2025</h3>
              <p class="text-gray-600 mt-4 text-sm leading-relaxed">
                Nuestros bebés más recientes. Una camada completa de gatos blancos.
              </p>
            </div>

            <div class="space-y-4">
              <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-blue-100">
                <img src={oddie.src} class="w-44 h-44 rounded-full object-cover border-2 border-blue-500" alt="Padre Oddie" />
                <div>
                  <p class="text-[10px] text-blue-500 font-black uppercase">Padre</p>
                  <p class="font-bold text-gray-800">Oddie</p>
                </div>
              </div>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-blue-100">
                <img src={blube.src} class="w-44 h-44 rounded-full object-cover border-2 border-blue-500" alt="Madre Bluey" />
                <div>
                  <p class="text-[10px] text-blue-500 font-black uppercase">Madre</p>
                  <p class="font-bold text-gray-800">Bluey</p>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:w-2/3 w-full grid grid-cols-1 sm:grid-cols-2 gap-6">
            {gatosEuropeo.filter(gato => gato.birth === "02/12/2025").map((europeo) => (
              <article class="group bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-blue-200">
                <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                  <img src={europeo.img} alt={europeo.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="px-2 pb-2">
                  <h4 class="text-lg font-bold text-gray-800">{europeo.name}</h4>
                  <div class="flex justify-between items-center mt-1">
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">{europeo.gender}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="chinchilla" class="max-w-6xl mx-auto px-4 pt-20 border-t border-gray-100">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-[#FF6B6B]">Línea Persa Chinchilla</h2>
        <div class="w-24 h-1 bg-[#FF6B6B] mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="bg-red-50/50 rounded-[3rem] p-8 md:p-12 mb-16 border border-red-100 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <div class="lg:w-1/3 w-full">
            <div class="mb-8">
              <span class="text-red-500 font-bold text-sm uppercase tracking-widest">Camada Verano</span>
              <h3 class="text-2xl font-bold text-gray-800 mt-2">22 de Junio de 2025</h3>
              <p class="text-gray-600 mt-4 text-sm leading-relaxed">
                Especialistas en mantos blancos y puntas sombreadas.
              </p>
            </div>
            <div class="space-y-4">
              <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-red-100">
                <img src={oddie.src} class="w-44 h-44 rounded-full object-cover border-2 border-red-500" alt="Padre Oddie" />
                <div><p class="text-[10px] text-red-500 font-black uppercase">Padre</p><p class="font-bold">Oddie</p></div>
              </div>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-red-100">
                <img src={ceres.src} class="w-44 h-44 rounded-full object-cover border-2 border-red-500" alt="Madre Ceres" />
                <div><p class="text-[10px] text-red-500 font-black uppercase">Madre</p><p class="font-bold">Ceres</p></div>
              </div>
            </div>
          </div>

          <div class="lg:w-2/3 w-full grid grid-cols-1 sm:grid-cols-2 gap-6">
            {gatosChinchilla.filter(gato => gato.birth === "22/06/2025").map((chinchilla) => (
              <article class="group bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-red-200">
                <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                  <img src={chinchilla.img} alt={chinchilla.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="px-2 pb-2">
                  <h4 class="text-lg font-bold text-gray-800">{chinchilla.name}</h4>
                  <div class="flex justify-between items-center mt-1">
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">{chinchilla.gender}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="bg-blue-50/50 rounded-[3rem] p-8 md:p-12 mb-16 border border-blue-100 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <div class="lg:w-1/3 w-full">
            <div class="mb-8">
              <span class="text-blue-500 font-bold text-sm uppercase tracking-widest">Camada Invierno</span>
              <h3 class="text-2xl font-bold text-gray-800 mt-2">06 de Diciembre de 2025</h3>
              <p class="text-gray-600 mt-4 text-sm leading-relaxed">
                Especialistas en mantos blancos y puntas sombreadas.
              </p>
            </div>
            <div class="space-y-4">
              <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-blue-100">
                <img src={oddie.src} class="w-44 h-44 rounded-full object-cover border-2 border-blue-500" alt="Padre Oddie" />
                <div><p class="text-[10px] text-blue-500 font-black uppercase">Padre</p><p class="font-bold">Oddie</p></div>
              </div>
              <div class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-blue-100">
                <img src={ceres.src} class="w-44 h-44 rounded-full object-cover border-2 border-blue-500" alt="Madre Ceres" />
                <div><p class="text-[10px] text-blue-500 font-black uppercase">Madre</p><p class="font-bold">Ceres</p></div>
              </div>
            </div>
          </div>

          <div class="lg:w-2/3 w-full grid grid-cols-1 sm:grid-cols-2 gap-6">
            {gatosChinchilla.filter(gato => gato.birth === "06/12/2025").map((chinchilla) => (
              <article class="group bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-blue-200">
                <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                  <img src={chinchilla.img} alt={chinchilla.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="px-2 pb-2">
                  <h4 class="text-lg font-bold text-gray-800">{chinchilla.name}</h4>
                  <div class="flex justify-between items-center mt-1">
                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-md">{chinchilla.gender}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="himalayo" class="max-w-6xl mx-auto px-4 py-20 border-t border-gray-100">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-[#FF6B6B] mb-8">Línea Persa Himalayo</h2>
        <div class="max-w-3xl mx-auto bg-gray-50 rounded-[2rem] p-10 border-2 border-dashed border-gray-200">
          <p class="text-gray-500 italic">Próximamente compartiremos nuestras primeras camadas de esta elegante variedad.</p>
          <a href="/principal/contacto" class="mt-6 inline-block bg-[#FF6B6B] text-white font-bold py-3 px-8 rounded-full hover:scale-105 transition-transform">
            Quiero que me aviséis
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>