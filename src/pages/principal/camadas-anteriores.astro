---
import Layout from "../../layouts/Layout.astro";
import oddie from "../../assets/img/nuestros_gatos/Oddie/oddie.jpg";
import blube from "../../assets/img/nuestros_gatos/Bluey/blube.jpg";
import ceres from "../../assets/img/nuestros_gatos/Ceres/ceres2.jpg";

import { gatosEuropeo } from "../../scripts/gatos-europeo anterior.js";
import { gatosChinchilla } from "../../scripts/gatos-chinchilla anterior.js";
import { gatosHimalayo } from "../../scripts/gatos-himalayo.js";

const camadasEuropeo = [
  { id: "eur-3", nombre: "Camada Primavera", fecha: "06 de Abril de 2026", filter: "23/03/2026", p: oddie, m: blube, desc: "Nuestros bebés más recientes. Una camada completa de gatos blancos." },
  { id: "eur-2", nombre: "Camada Otoño", fecha: "02 de Diciembre de 2025", filter: "02/12/2025", p: oddie, m: blube, desc: "Nuestros bebés más recientes. Una camada completa de gatos blancos." },
  { id: "eur-1", nombre: "Camada Primavera", fecha: "26 de Mayo de 2025", filter: "26/05/2025", p: oddie, m: blube, desc: "Una camada excepcional caracterizada por el temperamento equilibrado heredado de Bluey y el porte clásico de Oddie." }
];

const camadasChinchilla = [
  { id: "chi-3", nombre: "Camada Primavera", fecha: "06 de Abril de 2026", hover: "hover:border-pink-200", filter: "06/04/2026", p: oddie, m: ceres, desc: "Gatitos con mantos espectaculares." },
  { id: "chi-2", nombre: "Camada Otoño", fecha: "06 de Diciembre de 2025", hover: "hover:border-blue-200", filter: "06/12/2025", p: oddie, m: ceres, desc: "Puntas sombreadas y ojos esmeralda." },
  { id: "chi-1", nombre: "Camada Verano", fecha: "22 de Junio de 2025",  hover: "hover:border-red-200", filter: "22/06/2025", p: oddie, m: ceres, desc: "Especialistas en mantos blancos y puntas sombreadas." }
];
---

<Layout
  title="Camadas anteriores | Ágatha Gatos Persas"
  description="Descubre las camadas anteriores de gatos persas europeos, chinchilla e himalayos de nuestro criadero en Sevilla."
  keywords="camadas anteriores gato persa, criadero gatos persas Sevilla"
>
  <main class="min-h-screen bg-white text-[#2E2E2E] pt-20 pb-20">
    
    <section class="w-full bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white">
      <div class="max-w-6xl mx-auto px-4 py-12 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-white/80">
            Nuestra Historia · Transparencia y cariño
          </p>
          <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight">
            Camadas Anteriores
          </h1>
          <p class="max-w-xl text-sm md:text-base text-white/90 leading-relaxed">
            Cada gatito que ha pasado por <strong>Ágatha Gatos Persas</strong> es parte de nuestra familia. Aquí honramos su crecimiento y mostramos la calidad y salud de nuestras líneas de cría.
          </p>
        </div>
        
        <nav class="flex flex-col gap-3 bg-white/10 rounded-3xl p-6 border border-white/40 backdrop-blur-sm">
          <p class="font-semibold text-white text-lg">Explorar Variedades</p>
          <div class="flex flex-wrap gap-2">
            <a href="#europeo" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Europeo</a>
            <a href="#chinchilla" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Chinchilla</a>
            <a href="#himalayo" class="rounded-full border border-white text-white text-xs font-bold px-4 py-2 hover:bg-white hover:text-[#FF6B6B] transition-all">Himalayo</a>
          </div>
        </nav>
      </div>
    </section>

    <section id="europeo" class="max-w-7xl mx-auto px-4 pt-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-[#FF6B6B]">Línea Persa Europeo</h2>
        <div class="w-24 h-1 bg-[#FF6B6B] mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="flex justify-end gap-2 mb-6 max-w-6xl mx-auto sticky top-32 z-10">
        <button onclick="document.getElementById('slider-europeo').scrollBy({left: -600, behavior: 'smooth'})" class="p-3 rounded-full bg-gray-100 hover:bg-[#FF6B6B] hover:text-white transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button onclick="document.getElementById('slider-europeo').scrollBy({left: 600, behavior: 'smooth'})" class="p-3 rounded-full bg-gray-100 hover:bg-[#FF6B6B] hover:text-white transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <div id="slider-europeo" class="flex gap-8 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-10 px-4">
        {camadasEuropeo.map((camada) => (
          <div class="flex-none w-full max-w-6xl snap-center bg-[#FFF9F9] rounded-[3rem] p-8 md:p-12 border border-[#FFE4E4] shadow-sm">
            <div class="flex flex-col lg:flex-row gap-12 items-start">
              <div class="lg:w-1/3 w-full">
                <div class="mb-8">
                  <span class="font-bold text-sm uppercase tracking-widest text-[#FF8A8A]">{camada.nombre}</span>
                  <h3 class="text-2xl font-bold text-gray-800 mt-2">{camada.fecha}</h3>
                  <p class="text-gray-600 mt-4 text-sm leading-relaxed">{camada.desc}</p>
                </div>

                <div class="space-y-4">
                  <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
                  
                  <div class="flex items-center gap-4 bg-white p-4 rounded-3xl shadow-sm border border-[#FFE4E4]">
                    <img src={camada.p.src} class="w-24 h-24 sm:w-40 sm:h-40 rounded-full object-cover shadow-md border-2 border-[#FFEDED]" alt="Padre" />
                    <div>
                      <p class="text-[10px] text-[#FF8A8A] font-black uppercase">Padre</p>
                      <p class="font-bold text-gray-800">Oddie</p>
                    </div>
                  </div>

                  <div class="flex items-center gap-4 bg-white p-4 rounded-3xl shadow-sm border border-[#FFE4E4]">
                    <img src={camada.m.src} class="w-24 h-24 sm:w-40 sm:h-40 rounded-full object-cover shadow-md border-2 border-[#FFEDED]" alt="Madre" />
                    <div>
                      <p class="text-[10px] text-[#FF8A8A] font-black uppercase">Madre</p>
                      <p class="font-bold text-gray-800">Bluey</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="lg:w-2/3 w-full grid grid-cols-1 md:grid-cols-3 gap-6">
                {gatosEuropeo.filter(gato => gato.birth === camada.filter).map((europeo) => (
                  <article class="group relative bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-[#FFEDED]">
                    <!-- Botón de Favorito -->
                    <button 
                      class="favorite-btn absolute top-5 right-5 z-20 w-10 h-10 rounded-full bg-white/90 shadow-sm border border-[#FFE4E4] flex items-center justify-center transition-all hover:scale-110 active:scale-95 group/heart"
                      data-cat-id={`${europeo.name}#${europeo.birth}`}
                      data-cat-name={europeo.name}
                      data-cat-img={europeo.img}
                    >
                      <svg class="w-6 h-6 text-gray-300 transition-colors group-hover/heart:text-[#FF8A8A]" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                      </svg>
                    </button>

                    <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                      <img src={europeo.img} alt={europeo.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                    </div>
                    <div class="px-2 pb-2 text-center">
                      <h4 class="text-lg font-bold text-gray-800">{europeo.name}</h4>
                      <span class="text-xs text-gray-500 bg-[#FDF2F2] px-2 py-1 rounded-md">{europeo.gender}</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="chinchilla" class="max-w-7xl mx-auto px-4 pt-20 border-t border-gray-100">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-[#FF6B6B]">Línea Persa Chinchilla</h2>
        <div class="w-24 h-1 bg-[#FF6B6B] mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="flex justify-end gap-2 mb-6 max-w-6xl mx-auto sticky top-32 z-10">
        <button onclick="document.getElementById('slider-chinchilla').scrollBy({left: -600, behavior: 'smooth'})" class="p-3 rounded-full bg-gray-100 hover:bg-[#FF6B6B] hover:text-white transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button onclick="document.getElementById('slider-chinchilla').scrollBy({left: 600, behavior: 'smooth'})" class="p-3 rounded-full bg-gray-100 hover:bg-[#FF6B6B] hover:text-white transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <div id="slider-chinchilla" class="flex gap-8 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-10 px-4">
        {camadasChinchilla.map((camada) => (
          <div class="flex-none w-full max-w-6xl snap-center bg-[#FFF9F9] rounded-[3rem] p-8 md:p-12 border border-[#FFE4E4] shadow-sm">
            
            <div class="flex flex-col lg:flex-row gap-12 items-start">
              
              <div class="lg:w-1/3 w-full">
                <div class="mb-8">
                  <span class="font-bold text-sm uppercase tracking-widest text-[#FF8A8A]">{camada.nombre}</span>
                  <h3 class="text-2xl font-bold text-gray-800 mt-2">{camada.fecha}</h3>
                  <p class="text-gray-600 mt-4 text-sm leading-relaxed">{camada.desc}</p>
                </div>

                <div class="space-y-4">
                  <p class="font-bold text-gray-700 text-sm">Padres de la camada:</p>
                  
                  <div class="flex items-center gap-4 bg-white p-4 rounded-3xl shadow-sm border border-[#FFE4E4]">
                    <img src={camada.p.src} class="w-24 h-24 sm:w-40 sm:h-40 rounded-full object-cover shadow-md border-2 border-[#FFEDED]" alt="Padre" />
                    <div>
                      <p class="text-[10px] text-[#FF8A8A] font-black uppercase">Padre</p>
                      <p class="font-bold text-gray-800">Oddie</p>
                    </div>
                  </div>

                  <div class="flex items-center gap-4 bg-white p-4 rounded-3xl shadow-sm border border-[#FFE4E4]">
                    <img src={camada.m.src} class="w-24 h-24 sm:w-40 sm:h-40 rounded-full object-cover shadow-md border-2 border-[#FFEDED]" alt="Madre" />
                    <div>
                      <p class="text-[10px] text-[#FF8A8A] font-black uppercase">Madre</p>
                      <p class="font-bold text-gray-800">Ceres</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="lg:w-2/3 w-full grid grid-cols-1 md:grid-cols-3 gap-6">
                {gatosChinchilla.filter(gato => gato.birth === camada.filter).map((chinchilla) => (
                  <article class="group relative bg-white p-3 rounded-3xl shadow-md hover:shadow-xl transition-all border border-transparent hover:border-[#FFEDED]">
                    <!-- Botón de Favorito -->
                    <button 
                      class="favorite-btn absolute top-5 right-5 z-20 w-10 h-10 rounded-full bg-white/90 shadow-sm border border-[#FFE4E4] flex items-center justify-center transition-all hover:scale-110 active:scale-95 group/heart"
                      data-cat-id={`${chinchilla.name}#${chinchilla.birth}`}
                      data-cat-name={chinchilla.name}
                      data-cat-img={chinchilla.img}
                    >
                      <svg class="w-6 h-6 text-gray-300 transition-colors group-hover/heart:text-[#FF8A8A]" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                      </svg>
                    </button>

                    <div class="overflow-hidden rounded-2xl aspect-square mb-4">
                      <img src={chinchilla.img} alt={chinchilla.alt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                    </div>
                    <div class="px-2 pb-2 text-center">
                      <h4 class="text-lg font-bold text-gray-800">{chinchilla.name}</h4>
                      <span class="text-xs text-gray-500 bg-[#FDF2F2] px-2 py-1 rounded-md">{chinchilla.gender}</span>
                    </div>
                  </article>
                ))}
              </div>

            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="himalayo" class="max-w-7xl mx-auto px-4 pt-20 border-t border-gray-100">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-[#FF6B6B]">Línea Persa Himalayo</h2>
        <div class="w-24 h-1 bg-[#FF6B6B] mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="text-center">
        <div class="max-w-3xl mx-auto bg-gray-50 rounded-[2rem] p-10 border-2 border-dashed border-gray-200">
          <p class="text-gray-500 italic">Próximamente compartiremos nuestras primeras camadas de esta elegante variedad.</p>
          <a href="/principal/contacto" class="mt-6 inline-block bg-[#FF6B6B] text-white font-bold py-3 px-8 rounded-full hover:scale-105 transition-transform">
            Quiero que me aviséis
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .favorite-btn.active svg {
    color: #FF6B6B;
  }
</style>

<script>
  import { supabase } from "../../lib/supabase";

  async function initFavorites() {
    const { data: { session } } = await supabase.auth.getSession();
    const user = session?.user;

    const favoriteBtns = document.querySelectorAll('.favorite-btn');
    
    // Si hay usuario, cargar sus favoritos actuales
    let userFavorites = new Set();
    if (user) {
      const { data } = await supabase
        .from('favorites')
        .select('cat_id')
        .eq('user_id', user.id);
      
      if (data) {
        data.forEach(fav => userFavorites.add(fav.cat_id));
      }
    }

    favoriteBtns.forEach(btn => {
      const target = btn as HTMLButtonElement;
      const catId = target.dataset.catId;

      // Marcar botones activos
      if (catId && userFavorites.has(catId)) {
        target.classList.add('active');
      }

      target.addEventListener('click', async (e) => {
        e.preventDefault();
        
        if (!user) {
          alert("¡Inicia sesión para guardar a tus gatos favoritos! ❤️");
          window.location.href = "/login";
          return;
        }

        const isFavorite = target.classList.contains('active');
        const catName = target.dataset.catName;
        const catImg = target.dataset.catImg;

        if (isFavorite) {
          // Quitar de favoritos
          const { error } = await supabase
            .from('favorites')
            .delete()
            .eq('user_id', user.id)
            .eq('cat_id', catId);
          
          if (!error) target.classList.remove('active');
        } else {
          // Añadir a favoritos
          const { error } = await supabase
            .from('favorites')
            .insert({
              user_id: user.id,
              cat_id: catId,
              cat_name: catName,
              cat_img: catImg
            });
          
          if (!error) target.classList.add('active');
        }
      });
    });
  }

  // Ejecutar al cargar la página
  initFavorites();
</script>