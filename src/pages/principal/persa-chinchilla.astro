---
import Layout from "../../layouts/Layout.astro";
import oddie from "../../assets/img/oddie.jpg";
import ceres from "../../assets/img/ceres/ceres2.jpg";
import { gatosChinchilla } from "../../scripts/gatos-chinchilla.js";
import { gatosChinchilla as gatosChinchillaAnteriores } from "../../scripts/gatos-chinchilla anterior.js";
---

<Layout
	title="Gato persa chinchilla | Ágatha Gatos Persas"
	description="Conoce al encantador Gato Persa Europeo, una raza conocida por su belleza y carácter dulce. Descubre más sobre esta maravillosa raza en nuestro criadero."
	keywords="gato persa chinchilla, criadero de gatos persa, gatos persa en adopción"
>

	<main class="bg-white/90 text-[#2E2E2E] min-h-screen pb-10">
		<section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white py-20 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Gato Persa Chinchilla</h1>
				<div class="w-32 h-1 bg-white mx-auto mb-4"></div>
				<p class="text-white text-lg max-w-2xl mx-auto">
					Explora nuestra colección de gatos persas chinchilla, famosos por su pelaje plateado y su mirada cautivadora.
				</p>
			</div>
		</section>
		
		<section class="max-w-7xl mx-auto px-4 py-16">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-6">Nuestros Reproductores</h2>
				<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto"></div>
			</div>
			<div class="flex flex-col sm:flex-row gap-12 justify-center items-center">
				<figure class="bg-white p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 hover:cursor-pointer" id="oddieImg">
					<h3 class="text-2xl sm:text-3xl font-bold mb-4 text-[#FF6B6B]">Padre - Oddie</h3>
					<img src={oddie.src} alt="Padre gato persa chinchilla" loading="lazy" class="p-2 h-75 w-75 object-cover rounded-2xl bg-gradient-to-br from-[#FF6B6B] to-pink-400 shadow-lg"/>
				</figure>
				<figure class="bg-white p-6 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 hover:cursor-pointer" id="ceresImg">
					<h3 class="text-2xl sm:text-3xl font-bold mb-4 text-[#FF6B6B]">Madre - Ceres</h3>
					<img src={ceres.src} alt="Madre gato persa chinchilla" loading="lazy" class="p-2 h-75 w-75 object-cover rounded-2xl bg-gradient-to-br from-[#FF6B6B] to-pink-400 shadow-lg"/>
				</figure>
			</div>
    	</section>

		{gatosChinchilla.length === 0 && (
			<section class="bg-gradient-to-r from-gray-50 to-gray-100 py-20">
				<div class="max-w-4xl mx-auto px-4 text-center">
					<div class="text-6xl mb-6">😿</div>
					<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">¡Ups! No hay gatitos disponibles</h2>
					<p class="text-lg text-gray-700 mb-8 max-w-2xl mx-auto">
						Actualmente todos nuestros gatitos chinchilla están adoptados, pero puedes explorar nuestras camadas anteriores o dejarnos tu correo para avisarte cuando tengamos nuevos gatitos.
					</p>
					<div class="flex flex-col sm:flex-row gap-6 justify-center">
						<a href="/principal/camadas-anteriores" 
						class="inline-block bg-[#FF6B6B] hover:bg-[#e65c5c] hover:-translate-y-1 text-white font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Ver camadas anteriores
						</a>
						<a href="/principal/contacto" 
						class="inline-block border-2 border-[#FF6B6B] text-[#FF6B6B] hover:bg-[#FF6B6B] hover:text-white hover:-translate-y-1 font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Avisarme cuando haya gatitos
						</a>
					</div>
				</div>
			</section>
		)}

		{gatosChinchilla.length > 0 && (
			<section class="max-w-7xl mx-auto px-4 py-16">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-6">Gatitos Disponibles</h2>
					<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto mb-4"></div>
					<p class="text-gray-600 max-w-2xl mx-auto">Estos adorables gatitos están buscando su hogar definitivo</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
					{gatosChinchilla.map((gato) => (
						<article class="group bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 overflow-hidden border-2 border-pink-100 hover:border-[#FF6B6B]">
							<a href={`../gatos/${gato.slugChinchilla}`} class="relative block overflow-hidden aspect-square">
								<img 
									src={gato.img}
									alt={gato.alt} 
									loading="lazy" 
									class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
								/>
								<div class={gato.disponibleEstilo}>
									{gato.disponibleTexto}
								</div>
								<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-6">
									<span class="text-white text-lg font-bold">
										👁️ Ver detalles
									</span>
								</div>
							</a>
							
							<div class="p-6">
								<h3 class="text-2xl font-bold text-[#FF6B6B] mb-4">{gato.name}</h3>
								
								<div class="space-y-3 mb-6">
									<div class="flex items-center gap-2 text-gray-700">
										<span class="text-xl">
											{gato.gender === 'Macho' || gato.gender === 'Masculino' ? '💈' : '🎀'}
										</span>
										<span class="font-semibold text-sm">Género:</span>
										<span class="text-sm">{gato.gender}</span>
									</div>
									<div class="flex items-center gap-2 text-gray-700">
										<span class="text-xl">📅</span>
										<span class="font-semibold text-sm">Edad:</span>
										<span class="text-sm edad-gatito" data-nacimiento={gato.birth.toString()}>Calculando...</span>
									</div>
									<div class="flex items-center gap-2 text-gray-700">
										<span class="text-xl">🏠</span>
										<span class="font-semibold text-sm">Criado en:</span>
										<span class="text-sm">Entorno familiar</span>
									</div>
								</div>
								
								<!-- Botones de acción -->
								<div class="flex flex-col gap-3">
									<a 
										href="/principal/contacto" 
										class="w-full text-center bg-[#FF6B6B] hover:bg-[#e65c5c] text-white font-bold py-3 px-6 rounded-full transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-1"
									>
										❤️ Adoptar a {gato.name}
									</a>
									<a 
										href={`../gatos/${gato.slugChinchilla}`}
										class="w-full text-center border-2 border-[#FF6B6B] text-[#FF6B6B] hover:bg-[#FF6B6B] hover:text-white font-semibold py-3 px-6 rounded-full transition-all duration-300"
									>
										Ver perfil completo
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
			</section>
		)}

		<section class="bg-gradient-to-br from-gray-50 to-pink-50 py-20">
			<div class="max-w-7xl mx-auto px-4">
				<div class="text-center mb-12">
					<h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">Camadas Anteriores</h2>
					<div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto mb-6"></div>
					<p class="text-lg text-gray-700 max-w-2xl mx-auto">
						Mira algunos de nuestros gatitos chinchilla de camadas anteriores para que te hagas una idea de cómo crecen nuestros bebés.
					</p>
				</div>
				
				{gatosChinchillaAnteriores.length > 0 ? (
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 max-w-6xl mx-auto">
						{gatosChinchillaAnteriores.map((gatoAnterior) => (
							<figure class="bg-white p-4 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 hover:scale-105 cursor-pointer">
								<img 
									src={gatoAnterior.img} 
									alt={gatoAnterior.alt}
									loading="lazy" 
									class="w-full h-48 object-cover rounded-xl mb-3 bg-gradient-to-br from-[#FF6B6B] to-pink-400 p-1"
								/>
								<figcaption class="text-center">
									<p class="font-bold text-[#2E2E2E] text-sm">{gatoAnterior.name}</p>
									<p class="text-xs text-gray-600">{gatoAnterior.gender}</p>
								</figcaption>
							</figure>
						))}
					</div>
				) : (
					<div class="text-center text-gray-600">
						<p>Pronto agregaremos fotos de camadas anteriores.</p>
					</div>
				)}

				<div class="text-center mt-10">
					<a href="/principal/camadas-anteriores" 
						class="inline-block bg-[#FF6B6B] hover:bg-[#e65c5c] hover:-translate-y-1 text-white font-semibold py-3 px-8 rounded-full shadow-lg transition-all duration-300">
						Ver todas las camadas anteriores
					</a>
				</div>
			</div>
		</section>

		<script src="../../scripts/edad.js"></script>
		
		<script>
			gatoZoom("oddieImg", "oddieClick", "oddieCerrar");
			gatoZoom("ceresImg", "ceresClick", "ceresCerrar");

			function gatoZoom(
				gato: string,
				gatoImg: string,
				gatoCerrar: string,
			) {
				const gatoConst = document.getElementById(gato);
				const gatoImgConst = document.getElementById(gatoImg);
				const gatoCerrarConst = document.getElementById(gatoCerrar);

				gatoConst?.addEventListener("click", () => {
					gatoImgConst?.classList.remove(
						"opacity-0",
						"scale-90",
						"pointer-events-none",
					);
				});

				gatoCerrarConst?.addEventListener("click", () => {
					gatoImgConst?.classList.add(
						"opacity-0",
						"scale-90",
						"pointer-events-none",
					);
				});
			}
		</script>
	</main>
</Layout>