---
import Layout from "../../layouts/Layout.astro";
import oddie from "../../assets/img/nuestros_gatos/Oddie/oddie.jpg";
import ceres from "../../assets/img/nuestros_gatos/Ceres/ceres2.jpg";
import { gatosChinchilla } from "../../scripts/gatos-chinchilla.js";
import { gatosChinchilla as gatosChinchillaAnteriores } from "../../scripts/gatos-chinchilla anterior.js";
const chinchillaAleatorios = [...gatosChinchillaAnteriores]
    .sort(() => Math.random() - 0.5)
    .slice(0, 5);
---

<Layout
    title="Gato Persa Chinchilla | Ágatha Gatos Persas"
    description="Descubre la elegancia del Gato Persa Chinchilla. Pelaje plateado, ojos esmeralda y un carácter dulce en nuestro criadero familiar."
    keywords="gato persa chinchilla, criadero persa, adoptar gato chinchilla"
>
    <main class="bg-[#FFF9F9] text-[#2E2E2E] min-h-screen pb-10">
        <section
            class="relative bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white py-24 mt-16 overflow-hidden"
        >
            <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
                <h1
                    class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight"
                >
                    Gato Persa Chinchilla
                </h1>
                <div class="w-24 h-1.5 bg-white mx-auto mb-8 rounded-full">
                </div>
                <p
                    class="text-white/90 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed font-medium"
                >
                    Famosos por su pelaje plateado y su mirada cautivadora,
                    nuestros chinchillas son criados en un entorno de puro amor.
                </p>
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-4 py-20">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">
                    Nuestros Reproductores
                </h2>
                <div
                    class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto"
                >
                </div>
            </div>

            <div
                class="flex flex-col md:flex-row gap-10 justify-center items-center max-w-5xl mx-auto"
            >
                <figure
                    class="group relative bg-white p-4 rounded-[2.5rem] shadow-xl transition-all duration-500 hover:-translate-y-2 border border-pink-50"
                >
                    <div
                        class="absolute -top-4 -right-4 bg-[#FF6B6B] text-white px-6 py-2 rounded-full font-bold text-sm shadow-lg z-10"
                    >
                        Padre
                    </div>
                    <div class="overflow-hidden rounded-[2rem]">
                        <img
                            src={oddie.src}
                            alt="Oddie - Padre persa chinchilla"
                            class="w-80 h-80 object-cover transition-transform duration-700 group-hover:scale-110"
                        />
                    </div>
                    <figcaption class="text-center py-6">
                        <h3 class="text-2xl font-bold text-gray-800">Oddie</h3>
                    </figcaption>
                </figure>

                <figure
                    class="group relative bg-white p-4 rounded-[2.5rem] shadow-xl transition-all duration-500 hover:-translate-y-2 border border-pink-50"
                >
                    <div
                        class="absolute -top-4 -right-4 bg-[#FF8A8A] text-white px-6 py-2 rounded-full font-bold text-sm shadow-lg z-10"
                    >
                        Madre
                    </div>
                    <div class="overflow-hidden rounded-[2rem]">
                        <img
                            src={ceres.src}
                            alt="Ceres - Madre persa chinchilla"
                            class="w-80 h-80 object-cover transition-transform duration-700 group-hover:scale-110"
                        />
                    </div>
                    <figcaption class="text-center py-6">
                        <h3 class="text-2xl font-bold text-gray-800">Ceres</h3>
                    </figcaption>
                </figure>
            </div>
        </section>

        {
            gatosChinchilla.length === 0 && (
                <section class="max-w-5xl mx-auto px-4 mb-20">
                    <div class="bg-white rounded-[3rem] p-12 text-center shadow-2xl border-2 border-dashed border-[#FFC3C3] relative overflow-hidden">
                        <span class="text-6xl mb-6 block">✨</span>
                        <h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">
                            Próximas Camadas Chinchilla
                        </h2>
                        <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
                            Nuestros pequeños tesoros plateados han volado a sus
                            nuevos hogares. Estamos esperando nuevos bebés
                            pronto.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a
                                href="/principal/contacto"
                                class="bg-[#FF6B6B] text-white font-bold py-4 px-10 rounded-full shadow-lg hover:bg-[#ff5252] transition-all hover:scale-105"
                            >
                                Lista de Espera
                            </a>
                            <a
                                href="/principal/camadas-anteriores"
                                class="bg-white border-2 border-[#FF6B6B] text-[#FF6B6B] font-bold py-4 px-10 rounded-full hover:bg-[#FFF9F9] transition-all"
                            >
                                Ver Galería Chinchilla
                            </a>
                        </div>
                    </div>
                </section>
            )
        }

        {
            gatosChinchilla.length > 0 && (
                <section class="max-w-7xl mx-auto px-4 py-16">
                    <div class="text-center mb-16">
                        <h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-4">
                            Gatitos Disponibles
                        </h2>
                        <div class="w-32 h-1 bg-gradient-to-r from-[#FF6B6B] to-pink-400 mx-auto" />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-6xl mx-auto">
                        {gatosChinchilla.map((gato) => (
                            <article class="group bg-white rounded-[2.5rem] shadow-lg hover:shadow-[0_20px_50px_rgba(255,107,107,0.2)] transition-all duration-500 overflow-hidden border border-pink-50 cat-card">
                                <div class="relative aspect-[4/5] overflow-hidden">
                                    <img
                                        src={gato.images[0]}
                                        alt={gato.alt}
                                        class="cat-image w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                                        data-images={JSON.stringify(gato.images)}
                                        data-current-index="0"
                                    />

                                    {gato.images.length > 1 && (
                                        <div class="absolute inset-y-0 inset-x-0 flex items-center justify-between px-4 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300 z-30 pointer-events-none">
                                            <button 
                                                class="prev-image bg-white/40 backdrop-blur-md hover:bg-white/60 text-white p-2 rounded-xl border border-white/30 transition-all transform hover:scale-110 active:scale-95 pointer-events-auto"
                                                aria-label="Imagen anterior"
                                            >
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                                </svg>
                                            </button>
                                            <button 
                                                class="next-image bg-white/40 backdrop-blur-md hover:bg-white/60 text-white p-2 rounded-xl border border-white/30 transition-all transform hover:scale-110 active:scale-95 pointer-events-auto"
                                                aria-label="Siguiente imagen"
                                            >
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                </svg>
                                            </button>
                                        </div>
                                        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-1.5 z-30 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                                            {gato.images.map((_, i) => (
                                                <div class={`h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-6' : 'bg-white/40 w-1.5'} dot-indicator`} data-dot-index={i}></div>
                                            ))}
                                        </div>
                                    )}

                                    <div
                                        class={`absolute top-5 left-5 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest shadow-lg ${gato.disponibleEstilo}`}
                                    >
                                        {gato.disponibleTexto}
                                    </div>
                                </div>

                                <div class="p-8">
                                    <h3 class="text-3xl font-bold text-gray-800 mb-6">
                                        {gato.name}
                                    </h3>

                                    <div class="grid grid-cols-2 gap-3 mb-8">
                                        <div class="flex items-center gap-3 bg-[#fdf2f2] p-3 rounded-2xl border border-pink-100/50">
                                            <span class="text-xl">
                                                {gato.gender === "Macho" ||
                                                gato.gender === "Masculino"
                                                    ? "💈"
                                                    : "🎀"}
                                            </span>
                                            <span class="text-[11px] font-bold text-gray-800 uppercase tracking-tight">
                                                {gato.gender}
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-3 bg-[#fdf2f2] p-3 rounded-2xl border border-pink-100/50">
                                            <span class="text-xl">📅</span>
                                            <span
                                                class="text-[11px] font-bold text-gray-800 uppercase tracking-tight edad-gatito"
                                                data-nacimiento={gato.birth.toString()}
                                            >
                                                ...
                                            </span>
                                        </div>
                                        {gato.color && (
                                            <div class="flex items-center gap-3 bg-[#fdf2f2] p-3 rounded-2xl border border-pink-100/50">
                                                <span class="text-xl">🎨</span>
                                                <span class="text-[11px] font-bold text-gray-800 uppercase tracking-tight">
                                                    {gato.color}
                                                </span>
                                            </div>
                                        )}
                                    </div>

                                    <div class="flex flex-col gap-3">
                                        <a
                                            href="/contacto"
                                            class="w-full text-center bg-[#FF6B6B] text-white font-bold py-4 rounded-2xl transition-all hover:bg-[#ff5252] shadow-md active:scale-95"
                                        >
                                            ❤️ Adoptar a {gato.name}
                                        </a>
                                    </div>
                                </div>
                            </article>
                        ))}
                    </div>
                </section>
            )
        }

        <section class="bg-white py-24 border-y border-pink-100">
            <div class="max-w-7xl mx-auto px-4">
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
                    <h2 class="text-3xl md:text-4xl font-bold text-[#FF6B6B] mb-2">
                        Camadas anteriores
                    </h2>
                    </div>

                {
                    chinchillaAleatorios.length > 0 ? (
                        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8">
                            {chinchillaAleatorios.map((gatoAnterior) => (
                                <figure class="group">
                                    <div class="relative overflow-hidden rounded-[2rem] shadow-md mb-4 aspect-square border border-pink-50">
                                        <img
                                            src={gatoAnterior.images ? gatoAnterior.images[0] : gatoAnterior.img}
                                            alt={gatoAnterior.alt}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-pink-500/20 to-transparent" />
                                    </div>
                                    <figcaption class="text-center">
                                        <p class="font-bold text-gray-800 tracking-tight">
                                            {gatoAnterior.name}
                                        </p>
                                        <p class="text-[10px] text-[#FF8A8A] font-black uppercase tracking-[0.2em] mt-1">
                                            {gatoAnterior.gender}
                                        </p>
                                    </figcaption>
                                </figure>
                            ))}
                        </div>
                    ) : (
                        <div class="bg-[#FFF9F9] rounded-3xl p-10 text-center text-gray-400 font-medium">
                            Estamos preparando el archivo fotográfico...
                        </div>
                    )
                }
            </div>
        </section>

        <script src="../../scripts/edad.js"></script>
        <script>
            function initImageSwitcher() {
                const cards = document.querySelectorAll('.cat-card');
                
                cards.forEach(card => {
                    const img = card.querySelector('.cat-image');
                    const nextBtn = card.querySelector('.next-image');
                    const prevBtn = card.querySelector('.prev-image');
                    const dots = card.querySelectorAll('.dot-indicator');
                    
                    if (!img || !nextBtn || !prevBtn) return;
                    
                    const images = JSON.parse(img.dataset.images);
                    let currentIndex = 0;
                    
                    const updateImage = (index) => {
                        currentIndex = (index + images.length) % images.length;
                        img.src = images[currentIndex];
                        img.dataset.currentIndex = currentIndex;
                        
                        // Update dots
                        dots.forEach((dot, i) => {
                            if (i === currentIndex) {
                                dot.classList.replace('bg-white/40', 'bg-white');
                                dot.classList.replace('w-1.5', 'w-6');
                            } else {
                                dot.classList.replace('bg-white', 'bg-white/40');
                                dot.classList.replace('w-6', 'w-1.5');
                            }
                        });
                    };
                    
                    nextBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        updateImage(currentIndex + 1);
                    });
                    
                    prevBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        updateImage(currentIndex - 1);
                    });

                    // Swipe support
                    let touchStartX = 0;
                    let touchEndX = 0;
                    
                    card.addEventListener('touchstart', (e) => {
                        touchStartX = e.changedTouches[0].screenX;
                    }, { passive: true });
                    
                    card.addEventListener('touchend', (e) => {
                        touchEndX = e.changedTouches[0].screenX;
                        if (touchStartX - touchEndX > 50) {
                            updateImage(currentIndex + 1);
                        } else if (touchEndX - touchStartX > 50) {
                            updateImage(currentIndex - 1);
                        }
                    }, { passive: true });
                });
            }

            // Run on initial load
            initImageSwitcher();

            // Run on view transitions if active
            document.addEventListener('astro:page-load', initImageSwitcher);
        </script>
    </main>
</Layout>
