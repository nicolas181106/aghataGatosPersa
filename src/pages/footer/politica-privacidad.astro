---
import Layout from "../../layouts/Layout.astro";

const sections = [
    {
        title: "¿Qué datos recopilamos?",
        content: "Este sitio web no recopila datos personales de forma automática. Solo tratamos aquella información que el usuario facilita de forma voluntaria al contactar con nosotros a través de correo electrónico o formularios."
    },
    {
        title: "Finalidad del tratamiento",
        content: "La única finalidad del tratamiento de tus datos es responder a las consultas, dudas o comunicaciones que nos envíes. No utilizaremos tu información para el envío de publicidad no solicitada (spam)."
    },
    {
        title: "Legitimación",
        content: "La base legal para el tratamiento de tus datos es el consentimiento explícito que otorgas al pulsar el botón de envío en nuestras vías de contacto."
    },
    {
        title: "Conservación de datos",
        content: "Los datos personales proporcionados se conservarán únicamente durante el tiempo necesario para resolver tu solicitud. Una vez finalizada la comunicación, los datos serán eliminados de forma segura de nuestros registros."
    },
    {
        title: "Cesiones a terceros",
        content: "Ágatha Gatos Persas no cede, vende ni alquila datos personales a terceros bajo ninguna circunstancia, salvo obligación legal expresa."
    },
    {
        title: "Tus Derechos",
        content: "Como usuario, tienes derecho a acceder, rectificar o solicitar la eliminación de tus datos en cualquier momento. Para ejercer estos derechos, puedes escribirnos directamente a través de nuestra sección de contacto."
    },
]
---

<Layout
    title="Política de privacidad | Ágatha Gatos Persas"
    description="Cómo protegemos y gestionamos tus datos personales en Ágatha Gatos Persas."
>
    <main class="bg-[#FDFCFB] min-h-screen pb-16">
        
        <section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] py-20 mb-16 mt-20">
            <div class="max-w-7xl mx-auto px-4 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Política de Privacidad</h1>
                <div class="w-32 h-1 bg-white mx-auto mb-4"></div>
                <p class="text-white text-lg max-w-2xl mx-auto">
                    Cómo protegemos y gestionamos tus datos personales
                </p>
            </div>
        </section>

        <section class="max-w-4xl mx-auto px-6">
            <div class="bg-blue-50/50 border border-blue-100 rounded-[2.5rem] p-8 mb-12 flex items-start gap-6 shadow-sm">
                <div class="hidden sm:flex w-14 h-14 bg-white rounded-full items-center justify-center text-2xl shadow-sm flex-shrink-0 border border-blue-100">
                    🛡️
                </div>
                <div>
                    <h2 class="text-blue-900 font-bold text-lg leading-tight">Tu privacidad es prioritaria</h2>
                    <p class="text-blue-700/80 text-sm mt-2 leading-relaxed">
                        Cumplimos estrictamente con la normativa de protección de datos para garantizar que tu contacto con nosotros sea 100% seguro.
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-sm overflow-hidden">
                <div class="p-8 md:p-12 space-y-12">
                    {sections.map((section, index) => (
                        <div class="relative">
                            <div class="flex items-start gap-6">
                                <span class="hidden md:flex text-pink-100 text-4xl font-black select-none">
                                    {String(index + 1).padStart(2, '0')}
                                </span>
                                <article class="space-y-4">
                                    <h2 class="text-xl md:text-2xl font-black text-gray-900 tracking-tight">
                                        {section.title}
                                    </h2>
                                    <p class="text-gray-600 leading-[1.8] text-sm md:text-base">
                                        {section.content}
                                    </p>
                                </article>
                            </div>
                            {index !== sections.length - 1 && (
                                <div class="mt-12 border-b border-gray-50"></div>
                            )}
                        </div>
                    ))}
                </div>
                
                <div class="bg-gray-50 p-8 border-t border-gray-100 text-center">
                    <p class="text-xs text-gray-400 font-medium uppercase tracking-widest leading-relaxed">
                        Información actualizada según el RGPD europeo. <br/>
                        <a class="text-[#FF6B6B] hover:underline" href="/contacto">contacto</a>
                    </p>
                </div>
            </div>

            <div class="mt-12 text-center">
                <a href="/" class="inline-flex items-center gap-2 text-gray-400 font-bold hover:text-[#FF6B6B] transition-colors text-sm">
                    ← Volver a Inicio
                </a>
            </div>
        </section>
    </main>
</Layout>