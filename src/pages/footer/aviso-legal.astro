---
import Layout from "../../layouts/Layout.astro";

const sections = [
    {
        title: "Objeto",
        content: "El presente Aviso Legal regula el uso del sitio web agathagatospersas.es, propiedad de Nicolás Adrián Bernal Bermúdez. La navegación por este sitio web atribuye la condición de usuario e implica la aceptación plena y sin reservas de todas las disposiciones incluidas en este Aviso Legal."
    },
    {
        title: "Propiedad intelectual",
        content: "Todos los contenidos de la web (textos, imágenes, logotipos, vídeos, etc.) son propiedad del titular o tienen licencia de uso. Está prohibida su reproducción, distribución o transformación sin autorización expresa. El nombre comercial y logotipo de Ágatha Gatos Persas están protegidos por la normativa vigente."
    },
    {
        title: "Enlaces externos",
        content: "Este sitio puede contener enlaces a sitios de terceros (como Amazon o redes sociales). No nos responsabilizamos del contenido, seguridad o funcionamiento de dichos sitios, ni de las prácticas de privacidad que estos realicen fuera de nuestro dominio."
    },
    {
        title: "Responsabilidad",
        content: "El titular no se hace responsable de posibles errores en los contenidos, falta de disponibilidad temporal del sitio o transmisión de virus a pesar de haber tomado las medidas técnicas necesarias. El uso de este sitio web se realiza bajo responsabilidad exclusiva del usuario."
    },
]
---

<Layout
    title="Aviso legal | Ágatha Gatos Persas"
    description="Aviso legal y condiciones de uso de Ágatha Gatos Persas."
>
    <main class="bg-[#FDFCFB] min-h-screen pb-16">
        
        <section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] py-20 mb-16 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Aviso Legal</h1>
				<div class="w-32 h-1 bg-white mx-auto mb-4"></div>
				<p class="text-white text-lg max-w-2xl mx-auto">
					Información legal sobre el uso de este sitio web
				</p>
			</div>
		</section>

        <section class="max-w-4xl mx-auto px-6">
            <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-sm overflow-hidden">
                <div class="p-8 md:p-12 space-y-12">
                    {sections.map((section, index) => (
                        <div class="relative">
                            <div class="flex items-start gap-6">
                                <span class="hidden md:flex text-pink-100 text-4xl font-black select-none">
                                    {String(index + 1).padStart(2, '0')}
                                </span>
                                <article class="space-y-4">
                                    <h2 class="text-xl md:text-2xl font-black text-gray-900 tracking-tight">
                                        {section.title}
                                    </h2>
                                    <p class="text-gray-600 leading-[1.8] text-sm md:text-base">
                                        {section.content}
                                    </p>
                                </article>
                            </div>
                            {index !== sections.length - 1 && (
                                <div class="mt-12 border-b border-gray-50"></div>
                            )}
                        </div>
                    ))}
                </div>
                
                <div class="bg-gray-50 p-8 border-t border-gray-100 text-center">
                    <p class="text-xs text-gray-400 font-medium uppercase tracking-widest leading-relaxed">
                        Para cualquier duda legal contacte en <br/>
                        <a class="text-[#FF6B6B]" href="/contacto">contacto</a>
                    </p>
                </div>
            </div>

            <div class="mt-12 text-center">
                <a href="/" class="inline-flex items-center gap-2 text-gray-400 font-bold hover:text-[#FF6B6B] transition-colors text-sm">
                    ← Volver a Inicio
                </a>
            </div>
        </section>
    </main>
</Layout>