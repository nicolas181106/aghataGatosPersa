---
import Layout from "../../layouts/Layout.astro";

const sections = [
    {
        title: "¿Qué son las cookies?",
        content: "Las cookies son pequeños archivos de texto que los sitios web almacenan en el navegador del usuario. Suelen utilizarse para recordar preferencias, analizar el tráfico, mejorar la experiencia de navegación o personalizar contenido publicitario."
    },
    {
        title: "Uso de cookies en este sitio",
        content: "En Ágatha Gatos Persas priorizamos tu privacidad. Te informamos que este sitio web agathagatospersas.es no utiliza cookies propias ni de terceros para recopilar información de los usuarios, realizar seguimientos de navegación ni procesar datos personales de forma automatizada."
    },
    {
        title: "Navegación privada y segura",
        content: "Dado que no empleamos ningún tipo de tecnología de rastreo, no es necesario que aceptes ningún consentimiento de cookies al entrar. Tu navegación por nuestro catálogo y blog es completamente anónima y segura."
    },
]
---

<Layout
	title="Política de cookies | Ágatha Gatos Persas"
	description="Política de cookies de Ágatha Gatos Persas"
	keywords="gatos persas, cookies, política de cookies, política"
>
	<main class="bg-white/90 text-[#2E2E2E] min-h-screen pb-16">
		<section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] py-20 mb-16 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Política de Cookies</h1>
				<div class="w-32 h-1 bg-white mx-auto mb-4"></div>
				<p class="text-white text-lg max-w-2xl mx-auto">
					Información sobre el uso de cookies en este sitio
				</p>
			</div>
		</section>

		<section class="max-w-4xl mx-auto px-6">
            <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-sm overflow-hidden">
                <div class="p-8 md:p-12 space-y-12">
                    
                    <div class="bg-emerald-50/50 border border-emerald-100 rounded-[2rem] p-8 flex items-center gap-6">
                        <div class="hidden sm:flex w-16 h-16 bg-white rounded-full items-center justify-center text-3xl shadow-sm border border-emerald-100">
                            🍪
                        </div>
                        <div>
                            <p class="text-emerald-900 font-bold text-lg leading-tight">Privacidad por diseño</p>
                            <p class="text-emerald-700/80 text-sm mt-1 leading-relaxed">
                                Este sitio web <strong>no utiliza cookies</strong>. No rastreamos tu actividad ni instalamos archivos en tu dispositivo.
                            </p>
                        </div>
                    </div>

                    {sections.map((section, index) => (
                        <div class="relative">
                            <div class="flex items-start gap-6">
                                <span class="hidden md:flex text-pink-100 text-4xl font-black select-none">
                                    {String(index + 1).padStart(2, '0')}
                                </span>
                                <article class="space-y-4">
                                    <h2 class="text-xl md:text-2xl font-black text-gray-900 tracking-tight">
                                        {section.title}
                                    </h2>
                                    <p class="text-gray-600 leading-[1.8] text-sm md:text-base">
                                        {section.content}
                                    </p>
                                </article>
                            </div>
                            {index !== sections.length - 1 && (
                                <div class="mt-12 border-b border-gray-50"></div>
                            )}
                        </div>
                    ))}
                </div>
                
                <div class="bg-gray-50 p-8 border-t border-gray-100 text-center">
                    <p class="text-xs text-gray-400 font-medium uppercase tracking-widest leading-relaxed">
                        Si tienes dudas sobre tu privacidad, contacta en <br/>
                        <a class="text-[#FF6B6B] hover:underline" href="/contacto">contacto</a>
                    </p>
                </div>
            </div>

            <div class="mt-12 text-center">
                <a href="/" class="inline-flex items-center gap-2 text-gray-400 font-bold hover:text-[#FF6B6B] transition-colors text-sm">
                    ← Volver a Inicio
                </a>
            </div>
        </section>
	</main>
</Layout>
