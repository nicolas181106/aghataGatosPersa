---
import Layout from "../../layouts/Layout.astro";
import imgAreneroPrincipal from "./../../assets/img/arenero.jpg";

const areneros = [];
---

<Layout
  title="Areneros para Gatos Persas | Higiene y comodidad"
  description="Encuentra el arenero ideal para tu gato persa: bandejas XXL, areneros cerrados y opciones de fácil acceso para mantener la higiene de tu hogar."
  keywords="arenero gato, bandeja sanitaria gato, arenero XXL, arenero cerrado gato, arenero gato persa, higiene felina"
>
  <main class="backdrop-blur-[5px] text-[#2E2E2E] min-h-screen pb-16 mt-20">
    <section
      class="bg-gradient-to-r from-[#FF6B6B] via-[#FF8A8A] to-[#FFC0C0] text-white"
    >
      <div class="max-w-[1200px] mx-auto px-6 sm:px-10 py-8 sm:py-10">
        <nav class="text-[11px] sm:text-xs text-white/80 mb-2">
          <a href="/" class="hover:underline">Inicio</a>
          <span class="mx-1">/</span>
          <a href="/principal/productos" class="hover:underline">Productos</a>
          <span class="mx-1">/</span>
          <span class="font-semibold text-white">Areneros e Higiene</span>
        </nav>

        <h1
          class="text-2xl sm:text-3xl md:text-[32px] font-extrabold leading-snug"
        >
          Areneros y accesorios de higiene para gatos persas
        </h1>
        <p class="mt-2 text-[13px] sm:text-sm text-white/90 max-w-2xl">
          Mantener la higiene es clave para un hogar feliz. Elige areneros
          espaciosos y fáciles de limpiar para tu gato.
        </p>
      </div>
    </section>

    <section
      class="max-w-[1300px] mx-auto p-6 sm:p-10 mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3"
      aria-label="Catálogo de areneros para gatos"
    >
      {
        areneros.map((producto) => (
          <article class="group bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-200 flex flex-col border border-[#FFE2E2]/80 hover:border-[#FF6B6B]/80 hover:-translate-y-1.5 overflow-hidden">
            <div class="relative h-64 overflow-hidden">
              <img
                src={producto.img}
                alt={producto.alt}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-200"
                loading="lazy"
              />
              {producto.badge && (
                <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-black/55 text-white text-[11px] font-medium px-2.5 py-[3px]">
                  {producto.badge}
                </span>
              )}
            </div>

            <div class="p-4 sm:p-5 flex flex-col flex-1">
              <h3 class="text-[15px] sm:text-[16px] font-bold mb-1 text-[#111827]">
                {producto.h2}
              </h3>

              <p class="text-[13px] text-gray-700 leading-relaxed flex-1">
                {producto.p}
              </p>

              <p class="mt-2 text-[11px] text-emerald-700 font-medium">
                {producto.info}
              </p>

              <a
                href={producto.a}
                target="_blank"
                rel="nofollow noopener noreferrer"
                class="mt-4 inline-flex items-center justify-center gap-2 bg-[#FF6B6B] text-white font-semibold py-2.5 px-4 rounded-full hover:bg-[#e55a5a] text-[13px] text-center transition-colors"
              >
                Ver en Amazon
              </a>
            </div>
          </article>
        ))
      }
    </section>

    <div
      class="max-w-2xl mx-auto mt-12 p-6 bg-amber-50/50 border border-amber-100 rounded-2xl text-center shadow-sm"
    >
      <p class="text-[12px] text-amber-900/70 leading-relaxed">
        Comprar a través de estos enlaces nos ayuda a cubrir los gastos del
        criadero. Gracias por tu apoyo.
      </p>
    </div>

    <div class="flex justify-center mt-12">
      <a
        href="/principal/productos"
        class="bg-[#FF6B6B] text-white font-bold py-3 px-8 rounded-full shadow-lg transition-transform hover:scale-105 active:scale-95"
      >
        Volver a Productos
      </a>
    </div>
  </main>
</Layout>
