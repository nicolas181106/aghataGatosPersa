---
import Layout from "../../layouts/layout.astro";
import art1 from "./../../assets/img/rascadores/art1.jpg";
import art2 from "./../../assets/img/rascadores/art2.jpg";
import art3 from "./../../assets/img/rascadores/art3.jpg";
import art4 from "./../../assets/img/rascadores/art4.jpg";
import art5 from "./../../assets/img/rascadores/art5.jpg";
import art6 from "./../../assets/img/rascadores/art6.jpg";
import art7 from "./../../assets/img/rascadores/art7.jpg";
import art8 from "./../../assets/img/rascadores/art8.jpg";

const rascadores = [
  {
    a: "https://amzn.to/4s5h1cY",
    img: art1.src,
    alt: "Rascador alto Tyrol para gatos persas con pompón de peluche",
    h2: "Rascador Tyrol para Gatos Grandes con Juguete Integrado",
    p: "Rascador alto con poste de sisal natural y pompón colgante. Estable y resistente, ideal para gatos persas o gatos grandes que necesitan estirarse bien.",
  },
  {
    a: "https://amzn.to/4ssuCL8",
    img: art2.src,
    alt: "Árbol rascador JUPPLIES XXL para gatos persas",
    h2: "JUPPLIES Árbol Rascador XXL para Gatos (143 cm)",
    p: "Árbol rascador XXL con varios niveles, cestas acolchadas y hamaca. Perfecto para hogares con uno o varios gatos que disfrutan observando desde las alturas.",
  },
  {
    a: "https://amzn.to/4rXVxOZ",
    img: art3.src,
    alt: "Árbol rascador compacto de felpa y sisal para gatos persas",
    h2: "Árbol Rascador Compacto de Felpa y Sisal (85 cm)",
    p: "Rascador compacto con cueva, plataformas y pelota colgante. Ideal para espacios pequeños y gatos persas que prefieren alturas moderadas.",
  },
  {
    a: "https://amzn.to/4ssuLOG",
    img: art4.src,
    alt: "Poste de repuesto Trixie para rascadores de gatos en color beige",
    h2: "Trixie Poste de Repuesto para Rascadores (9×40 cm)",
    p: "Poste de repuesto envuelto en sisal natural para renovar rascadores y árboles. Incluye varilla roscada y tornillos para un montaje sencillo.",
  },
  {
    a: "https://amzn.to/47wQJYI",
    img: art5.src,
    alt: "Árbol rascador Nobleza para gatos beige con pelota colgante",
    h2: "Nobleza – Árbol Rascador para Gatos (41×35×60 cm, Beige)",
    p: "Rascador compacto con poste de sisal natural, base estable y pelota colgante. Ideal para gatos persas que necesitan un rincón propio para rascar.",
  },
  {
    a: "https://amzn.to/47APmZ4",
    img: art6.src,
    alt: "Rascador de cartón VIVAGLORY con caja y hierba gatera para gatos de interior",
    h2: "VIVAGLORY – Rascador de Cartón con Caja y Hierba Gatera",
    p: "Rascador de cartón reversible con marco que mantiene el suelo limpio. Incluye hierba gatera natural y diseño ecológico.",
  },
  {
    a: "https://amzn.to/47Bnt35",
    img: art7.src,
    alt: "Rascador para gatos Nobleza de 80 cm con pelota y muelle gris",
    h2: "Nobleza – Rascador para Gatos (80 cm, Gris)",
    p: "Poste rascador de 80 cm con base reforzada, sisal natural y pelotas de juego. Ofrece estabilidad y altura suficiente para gatos medianos y grandes.",
  },
  {
    a: "https://amzn.to/4s3hQ6a",
    img: art8.src,
    alt: "Poste rascador marrón para gatos con felpa y sisal",
    h2: "SWR – Poste Rascador para Gatos (35×25×25 cm, Marrón)",
    p: "Rascador compacto con poste de sisal natural y base de felpa suave. Ideal como rascador secundario o para zonas concretas de la casa.",
  },
];
---

<Layout
  title="Rascadores para Gatos | Mejores Rascadores y Árboles para Gatos 2025"
  description="Descubre los mejores rascadores para gatos: árboles rascadores, postes de sisal y modelos XXL. Protege tus muebles y cuida las uñas de tu gato con productos bien valorados."
  keywords="rascadores para gatos, rascadores para gatos persas, rascador de gato, rascadores gatos, árbol rascador, rascador gato grande, poste rascador, rascador sisal, rascador felpa, mejores rascadores para gatos"
>
  <main class="backdrop-blur-[5px] text-[#2E2E2E] min-h-screen pb-16 mt-20">
    <section class="bg-gradient-to-r from-[#FF6B6B] via-[#FF8A8A] to-[#FFC0C0] text-white">
      <div class="max-w-[1200px] mx-auto px-6 sm:px-10 py-8 sm:py-10">
        <nav class="text-[11px] sm:text-xs text-white/80 mb-2">
          <a href="/" class="hover:underline">Inicio</a>
          <span class="mx-1">/</span>
          <a href="/principal/productos" class="hover:underline">Productos</a>
          <span class="mx-1">/</span>
          <span class="font-semibold text-white">Rascadores para gatos</span>
        </nav>

        <h1 class="text-2xl sm:text-3xl md:text-[32px] font-extrabold leading-snug">
          Rascadores y árboles para gatos: Mejores modelos 2026
        </h1>
        <p class="mt-2 text-[13px] sm:text-sm text-white/90 max-w-2xl">
          Selección de <strong>rascadores y árboles para gatos</strong> pensados para proteger tus muebles y dar a tu gato un lugar propio donde estirarse, rascar y descansar.
        </p>
        <p class="mt-2 text-[12px] sm:text-xs text-white/80 max-w-2xl">
          Los gatos persas suelen agradecer superficies estables, postes de sisal natural y alturas moderadas que no les obliguen a saltar en exceso.
        </p>

        <div class="mt-4 flex flex-wrap gap-2 text-[11px] sm:text-[12px]">
          <span class="px-3 py-1 rounded-full bg-white/15 border border-white/30">Árboles rascadores</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/20">Postes de sisal</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/20">Rascadores compactos</span>
          <span class="px-3 py-1 rounded-full bg-white/10 border border-white/20">Modelos XXL</span>
        </div>
      </div>
    </section>

    <section class="max-w-full sm:max-w-[600px] lg:max-w-4xl sm:mx-auto sm:mt-12 p-8 bg-white sm:rounded-3xl shadow-xl border border-gray-100 text-gray-800 pop">
      <h2 class="text-2xl lg:text-3xl font-black text-[#FF6B6B] mb-6 text-center tracking-tight">
        Cómo elegir el mejor rascador para tu gato
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-gray-600">
        <p>
          Los <strong>rascadores para gatos</strong> ayudan a mantener sus uñas en buen estado, liberar energía y marcar territorio sin destrozar el sofá. Para un gato persa, la estabilidad y la comodidad son clave: materiales suaves, buena base y postes de <strong>sisal natural</strong>.
        </p>
        
        <div class="p-5 bg-pink-50 rounded-xl border-l-4 border-[#FF6B6B]">
          <p class="text-gray-700 m-0">
            Piensa en el espacio disponible en casa y en la personalidad de tu gato. <strong>Consejo experto:</strong> Si tu gato es tranquilo o mayor, prioriza rascadores con cuevas a ras de suelo; si es joven, un árbol con diferentes niveles fomentará su ejercicio diario.
          </p>
        </div>
      </div>
    </section>

    <section
      class="max-w-[1300px] mx-auto p-6 sm:p-10 mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3"
      aria-label="Catálogo de rascadores para gatos"
    >
      {rascadores.map((producto) => (
        <article class="group bg-white rounded-2xl pop shadow-sm hover:shadow-md transition-all duration-200 flex flex-col border border-[#FFE2E2]/80 hover:border-[#FF6B6B]/80 hover:-translate-y-1.5 overflow-hidden">
          <div class="relative h-64 overflow-hidden">
            <img
              src={producto.img}
              alt={producto.alt}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-200"
              loading="lazy"
            />
          </div>

          <div class="p-4 sm:p-5 flex flex-col flex-1">
            <h3 class="text-[15px] sm:text-[16px] font-bold mb-1 text-[#111827]">
              {producto.h2}
            </h3>

            <p class="text-[13px] text-gray-700 leading-relaxed flex-1">
              {producto.p}
            </p>

            <a
              href={producto.a}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="mt-4 inline-flex items-center justify-center gap-2 bg-[#FF6B6B] text-white font-semibold py-2.5 px-4 rounded-full hover:bg-[#e55a5a] text-[13px] text-center transition-colors"
            >
              Comprar en Amazon
            </a>
          </div>
        </article>
      ))}
    </section>

    <div class="max-w-80 sm:max-w-2xl mx-auto mt-16 p-6 bg-amber-50/50 border border-amber-200 rounded-2xl shadow-sm text-center">
      <div class="flex items-center justify-center gap-2 text-amber-700 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
        <h3 class="font-bold text-xs uppercase tracking-widest">Aviso de Transparencia</h3>
      </div>

      <p class="text-sm md:text-[15px] text-amber-900/80 leading-relaxed">
        Nuestras recomendaciones de <strong>accesorios felinos</strong> se basan en la calidad y estabilidad de los materiales. Al realizar tus compras a través de nuestros enlaces, nos ayudas a mantener este sitio informativo activo sin coste extra para ti.
      </p>
    </div>

    <div class="flex justify-center mt-12">
      <a
        href="/principal/productos"
        class="group flex items-center gap-2 bg-[#FF6B6B] hover:bg-[#ff5252] text-white font-bold py-4 px-8 rounded-full shadow-lg hover:shadow-xl shadow-red-200 transition-all duration-300 transform hover:scale-105 active:scale-95 text-lg pop"
      >
        Ver todas las categorías
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </main>
</Layout>