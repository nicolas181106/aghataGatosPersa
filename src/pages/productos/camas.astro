---
import Layout from "../../layouts/Layout.astro";
import art1 from "./../../assets/img/productos/camas/art1.jpg";
import art2 from "./../../assets/img/productos/camas/art2.jpg";
import art3 from "./../../assets/img/productos/camas/art3.jpg";
import art4 from "./../../assets/img/productos/camas/art4.jpg";
import art5 from "./../../assets/img/productos/camas/art5.jpg";
import art6 from "./../../assets/img/productos/camas/art6.jpg";
import art7 from "./../../assets/img/productos/camas/art7.jpg";
import art8 from "./../../assets/img/productos/camas/art8.jpg";
import art9 from "./../../assets/img/productos/camas/art9.jpg";
import art10 from "./../../assets/img/productos/camas/art10.jpg";
import art11 from "./../../assets/img/productos/camas/art11.jpg";
import art12 from "./../../assets/img/productos/camas/art12.jpg";

const productos = [
  // CAMAS
  {
    a: "https://amzn.to/4uevTX1",
    img: art1.src,
    h2: "Cama Redonda Amazon Basics – Franela",
    p: "Cama acolchada ultra suave con borde elevado. Perfecta para que tu gato se sienta protegido y cómodo durante sus siestas.",
    tipo: "camas",
  },
  {
    a: "https://amzn.to/4cRLrsH",
    img: art2.src,
    h2: "Bedsure – Cama de Felpa Sherpa",
    p: "Superficie de sherpa mullido para una suavidad máxima. Ofrece un entorno cálido y acogedor para el descanso diario.",
    tipo: "camas",
  },
  {
    a: "https://amzn.to/4vWURfr",
    img: art3.src,
    h2: "Bedsure – Cama Lavable Reversible",
    p: "Cama versátil con cojín extraíble para usar en cualquier época del año. Fácil de lavar y muy duradera.",
    tipo: "camas",
  },
  {
    a: "https://amzn.to/3OwRL0U",
    img: art4.src,
    h2: "Bedsure – Cueva Refugio para Gatos",
    p: "Tienda acogedora con cojín de felpa. El escondite perfecto para gatos que buscan tranquilidad y seguridad.",
    tipo: "camas",
  },
  {
    a: "https://amzn.to/4dgTjW0",
    img: art5.src,
    h2: "Cama 2 en 1 – Esterilla y Sofá",
    p: "Diseño convertible que se adapta a las preferencias de tu mascota. Felpa suave combinada con lino resistente.",
    tipo: "camas",
  },

  // TRANSPORTINES
  {
    a: "https://amzn.to/3R0FNgC",
    img: art6.src,
    h2: "Morpilot – Transportín Plegable Premium",
    p: "Diseño transpirable con correa ajustable y plegado fácil. Ideal para viajes seguros y cómodos en cualquier transporte.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/4tIUxiI",
    img: art7.src,
    h2: "Bolsa de Transporte Transpirable XL",
    p: "Incluye colchón suave y tazón plegable. Medidas amplias para máxima comodidad durante traslados largos.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/42cuCE1",
    img: art8.src,
    h2: "Nobleza – Transportín Rígido Clásico",
    p: "Estructura de plástico resistente con ventilación lateral. Seguro, duradero y muy fácil de limpiar tras su uso.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/4wca8sU",
    img: art9.src,
    h2: "Transportín Extensible 4 Entradas",
    p: "Mochila impermeable con arnés interno y diseño extensible. Ofrece el máximo espacio y ventilación para viajes de hasta 8kg.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/3OFmNUn",
    img: art10.src,
    h2: "Amazon Basics – Transportín Suave",
    p: "Aprobado por aerolíneas, plegable y con ventilación de malla. Perfecto para traslados ligeros y viajes en cabina.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/4d3fHRK",
    img: art11.src,
    h2: "Conlun – Bolsa de Viaje Plegable",
    p: "Portador suave con correa interior de seguridad para gatos de hasta 7kg. Diseño plegable que ahorra espacio tras su uso.",
    tipo: "transportines",
  },
  {
    a: "https://amzn.to/4tczuEe",
    img: art12.src,
    h2: "Trixie – Transportín Sostenible Be Eco",
    p: "Fabricado con plástico reciclado de alta calidad. Talla XS, ideal para visitas seguras al veterinario y viajes cortos.",
    tipo: "transportines",
  },
];

const camas = productos.filter((p) => p.tipo === "camas");
const transportines = productos.filter((p) => p.tipo === "transportines");
---

<Layout
  title={`Las Mejores Camas y Transportines ${new Date().getFullYear()} | Descanso y Viaje`}
  description="Guía completa para el descanso y traslado de tu gato: camas antiestrés, cuevas y transportines seguros para viajar."
  keywords="camas para gatos, transportines gatos, mochila gato, cueva gato, descanso felino, viajar con gato"
>
  <main class="bg-white/70 text-[#2E2E2E] min-h-screen pb-16 mt-20">
    <section
      class="bg-gradient-to-r from-[#FF6B6B] via-[#FF8A8A] to-[#FFC0C0] text-white"
    >
      <div class="max-w-[1200px] mx-auto px-6 sm:px-10 py-8 sm:py-10">
        <nav class="text-[11px] sm:text-xs text-white/80 mb-2">
          <a href="/" class="hover:underline">Inicio</a>
          <span class="mx-1">/</span>
          <a href="/principal/productos" class="hover:underline">Productos</a>
          <span class="mx-1">/</span>
          <span class="font-semibold text-white">Camas y Transportines</span>
        </nav>

        <h1
          class="text-2xl sm:text-3xl md:text-[32px] font-extrabold leading-snug"
        >
          Camas y Transportines: Confort en Casa y de Viaje
        </h1>
        <p class="mt-2 text-[13px] sm:text-sm text-white/90 max-w-2xl">
          Desde el descanso más profundo en casa hasta la máxima seguridad en
          tus traslados. Hemos seleccionado lo mejor para tu gato.
        </p>

        <div class="mt-4 flex flex-wrap gap-2 text-[11px] sm:text-[12px]">
          <span
            class="px-3 py-1 rounded-full bg-white/15 border border-white/30"
            >Camas antiestrés</span
          >
          <span
            class="px-3 py-1 rounded-full bg-white/10 border border-white/20"
            >Transportines rígidos</span
          >
          <span
            class="px-3 py-1 rounded-full bg-white/10 border border-white/20"
            >Mochilas panorámicas</span
          >
          <span
            class="px-3 py-1 rounded-full bg-white/10 border border-white/20"
            >Cuevas acogedoras</span
          >
        </div>
      </div>
    </section>

    <!-- SUBMENÚ DE NAVEGACIÓN -->
    <nav
      class="sticky top-[80px] z-40 bg-white/90 backdrop-blur-md border-b border-pink-100 shadow-md"
    >
      <div
        class="max-w-[1200px] mx-auto px-6 py-3 flex items-center justify-start sm:justify-center gap-4 sm:gap-10 overflow-x-auto whitespace-nowrap scrollbar-hide"
      >
        <a
          href="#camas"
          class="text-xs sm:text-sm font-bold text-[#FF6B6B] hover:bg-pink-50 px-6 py-3 rounded-full transition-colors flex items-center gap-2"
        >
          <span class="w-2 h-2 rounded-full bg-[#FF6B6B]"></span>
          Camas y Descanso
        </a>
        <a
          href="#transportines"
          class="text-xs sm:text-sm font-bold text-amber-600 hover:bg-amber-50 px-6 py-3 rounded-full transition-colors flex items-center gap-2"
        >
          <span class="w-2 h-2 rounded-full bg-amber-600"></span>
          Transportines y Viaje
        </a>
      </div>
    </nav>

    <section
      class="max-w-full sm:max-w-[600px] lg:max-w-4xl sm:mx-auto sm:mt-12 p-8 bg-white sm:rounded-3xl shadow-xl border border-gray-100 text-gray-800 pop"
    >
      <h2
        class="text-2xl lg:text-3xl font-black text-[#FF6B6B] mb-6 text-center tracking-tight"
      >
        Guía de descanso y traslado experto
      </h2>

      <div class="space-y-5 text-lg leading-relaxed text-gray-600">
        <p>
          Un gato necesita sentirse seguro tanto para dormir como para viajar.
          Los <strong>gatos persas</strong>, al ser más tranquilos, valoran
          especialmente las camas mullidas y los transportines con buena
          visibilidad y ventilación.
        </p>

        <div class="p-5 bg-pink-50 rounded-xl border-l-4 border-[#FF6B6B]">
          <p class="text-gray-700 m-0">
            <strong>Consejo experto:</strong> Deja el transportín abierto en casa
            como si fuera una cama más. Así, cuando llegue el momento de viajar, tu
            gato lo verá como un refugio seguro y no como algo negativo.
          </p>
        </div>
      </div>
    </section>

    <!-- SECCIÓN CAMAS -->
    <section
      id="camas"
      class="max-w-[1300px] mx-auto px-6 sm:px-10 mt-16 scroll-mt-32"
    >
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-2xl md:text-3xl font-black text-[#FF6B6B]">
          Camas y Descanso
        </h2>
        <div class="h-[2px] bg-pink-100 flex-1"></div>
        <span
          class="px-4 py-1 bg-pink-50 text-[#FF6B6B] rounded-full text-xs font-bold uppercase tracking-widest"
          >Descanso</span
        >
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          camas.map((producto) => (
            <article class="group bg-white rounded-2xl pop shadow-sm hover:shadow-md transition-all duration-200 flex flex-col border border-[#FFE2E2]/80 hover:border-[#FF6B6B]/80 hover:-translate-y-1.5 overflow-hidden">
              <div class="relative h-64 overflow-hidden">
                <img
                  src={producto.img}
                  alt={producto.h2}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-200"
                  loading="lazy"
                />
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-1">
                <h3 class="text-[15px] sm:text-[16px] font-bold mb-1 text-[#111827]">
                  {producto.h2}
                </h3>
                <p class="text-[13px] text-gray-700 leading-relaxed flex-1">
                  {producto.p}
                </p>
                <a
                  href={producto.a}
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                  class="mt-4 inline-flex items-center justify-center gap-2 bg-[#FF6B6B] text-white font-semibold py-2.5 px-4 rounded-full hover:bg-[#e55a5a] text-[13px] text-center transition-colors"
                >
                  Comprar en Amazon
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- SECCIÓN TRANSPORTINES -->
    <section
      id="transportines"
      class="max-w-[1300px] mx-auto px-6 sm:px-10 mt-20 scroll-mt-32"
    >
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-2xl md:text-3xl font-black text-amber-700">
          Transportines y Viaje
        </h2>
        <div class="h-[2px] bg-amber-100 flex-1"></div>
        <span
          class="px-4 py-1 bg-amber-50 text-amber-600 rounded-full text-xs font-bold uppercase tracking-widest"
          >Seguridad</span
        >
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          transportines.map((producto) => (
            <article class="group bg-white rounded-2xl pop shadow-sm hover:shadow-md transition-all duration-200 flex flex-col border border-amber-100 hover:border-amber-300 hover:-translate-y-1.5 overflow-hidden">
              <div class="relative h-64 overflow-hidden">
                <img
                  src={producto.img}
                  alt={producto.h2}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-200"
                  loading="lazy"
                />
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-1">
                <h3 class="text-[15px] sm:text-[16px] font-bold mb-1 text-[#111827]">
                  {producto.h2}
                </h3>
                <p class="text-[13px] text-gray-700 leading-relaxed flex-1">
                  {producto.p}
                </p>
                <a
                  href={producto.a}
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                  class="mt-4 inline-flex items-center justify-center gap-2 bg-amber-600 text-white font-semibold py-2.5 px-4 rounded-full hover:bg-amber-700 text-[13px] text-center transition-colors"
                >
                  Comprar en Amazon
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <div
      class="max-w-80 sm:max-w-2xl mx-auto mt-16 p-6 bg-amber-50/50 border border-amber-200 rounded-2xl shadow-sm text-center"
    >
      <div class="flex items-center justify-center gap-2 text-amber-700 mb-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
            clip-rule="evenodd"></path>
        </svg>
        <h3 class="font-bold text-xs uppercase tracking-widest">
          Transparencia y Confort
        </h3>
      </div>

      <p class="text-sm md:text-[15px] text-amber-900/80 leading-relaxed">
        Nuestras recomendaciones se basan en la calidad y seguridad para tus
        gatos. Al comprar a través de estos enlaces, nos ayudas a seguir
        cuidando de nuestros pequeños sin coste extra para ti.
      </p>
    </div>

    <div class="flex justify-center mt-12">
      <a
        href="/principal/productos"
        class="group flex items-center gap-2 bg-[#FF6B6B] hover:bg-[#ff5252] text-white font-bold py-4 px-8 rounded-full shadow-lg hover:shadow-xl shadow-red-200 transition-all duration-300 transform hover:scale-105 active:scale-95 text-lg pop"
      >
        Ver todas las categorías
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </main>
</Layout>
