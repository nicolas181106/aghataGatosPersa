---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Iniciar Sesión | Ágatha Gatos Persas"
    description="Inicia sesión en tu cuenta de Ágatha Gatos Persas."
>
    <!-- Background similar to index.astro headers -->
    <main
        class="min-h-screen bg-[#FAF9F6] flex items-center justify-center pt-24 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden"
    >
        <!-- Decorative blobs -->
        <div
            class="absolute top-0 left-0 w-64 h-64 bg-pink-100 rounded-full blur-3xl opacity-50 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 right-0 w-96 h-96 bg-[#FF6B6B]/10 rounded-full blur-3xl opacity-50 translate-x-1/3 translate-y-1/3 pointer-events-none"
        >
        </div>

        <div
            class="max-w-md w-full relative z-10 bg-white p-10 rounded-[3rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-pink-50 transition-all duration-500 hover:shadow-2xl"
        >
            <div class="text-center mb-8">
                <div
                    class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-pink-50 text-[#FF6B6B] mb-4"
                >
                    <svg
                        class="w-8 h-8"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"
                        ></path></svg
                    >
                </div>
                <h2 class="text-3xl font-black text-[#2E2E2E] mb-2">
                    Bienvenido de nuevo
                </h2>
                <p class="text-gray-500">Inicia sesión en tu cuenta</p>
            </div>

            <!-- Error/Success Alerts -->
            <div
                id="auth-alert"
                class="hidden mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300"
            >
            </div>

            <form id="login-form" class="space-y-6">
                <div>
                    <label
                        for="email"
                        class="block text-sm font-bold text-gray-700 mb-2"
                        >Correo Electrónico</label
                    >
                    <input
                        type="email"
                        id="email"
                        required
                        class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all duration-300 text-black"
                        placeholder="tu@email.com"
                    />
                </div>

                <div>
                    <label
                        for="password"
                        class="block text-sm font-bold text-gray-700 mb-2"
                        >Contraseña</label
                    >
                    <input
                        type="password"
                        id="password"
                        required
                        class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all duration-300 text-black"
                        placeholder="••••••••"
                    />
                </div>

                <button
                    type="submit"
                    id="submit-btn"
                    class="w-full bg-[#FF6B6B] hover:bg-[#e65c5c] text-white font-bold py-3.5 px-6 rounded-2xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 flex justify-center items-center gap-2"
                >
                    <span>Iniciar Sesión</span>
                    <span
                        id="spinner"
                        class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"
                    ></span>
                </button>
            </form>

            <p class="mt-8 text-center text-sm text-gray-600">
                ¿No tienes una cuenta?
                <a
                    href="/register"
                    class="font-bold text-[#FF6B6B] hover:text-[#e65c5c] hover:underline transition-colors"
                    >Regístrate aquí</a
                >
            </p>
        </div>
    </main>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    const loginForm = document.getElementById("login-form") as HTMLFormElement;
    const alertBox = document.getElementById("auth-alert");
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const spinner = document.getElementById("spinner");
    const btnText = submitBtn.querySelector("span");

    const showAlert = (message: string, isError: boolean = true) => {
        if (!alertBox) return;
        alertBox.textContent = message;
        alertBox.className = `mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300 block ${
            isError
                ? "bg-red-50 text-red-600 border border-red-100"
                : "bg-green-50 text-green-600 border border-green-100"
        }`;
    };

    const setLoading = (loading: boolean) => {
        submitBtn.disabled = loading;
        if (loading) {
            spinner?.classList.remove("hidden");
            if (btnText) btnText.textContent = "Iniciando sesión...";
        } else {
            spinner?.classList.add("hidden");
            if (btnText) btnText.textContent = "Iniciar Sesión";
        }
    };

    loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const email = (document.getElementById("email") as HTMLInputElement)
            .value;
        const password = (
            document.getElementById("password") as HTMLInputElement
        ).value;

        setLoading(true);
        if (alertBox) alertBox.classList.add("hidden");

        try {
            const { data, error } = await supabase.auth.signInWithPassword({
                email,
                password,
            });

            if (error) throw error;

            showAlert("¡Inicio de sesión exitoso! Redirigiendo...", false);
            setTimeout(() => {
                window.location.href = "/";
            }, 1000);
        } catch (error: any) {
            showAlert(error.message || "Error al iniciar sesión");
        } finally {
            setLoading(false);
        }
    });
</script>
