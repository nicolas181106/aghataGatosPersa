---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Recuperar Contraseña | Ágatha Gatos Persas"
    description="Recupera el acceso a tu cuenta."
>
    <main class="min-h-screen bg-[#FAF9F6] flex items-center justify-center pt-24 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-64 h-64 bg-pink-100 rounded-full blur-3xl opacity-50 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#FF6B6B]/10 rounded-full blur-3xl opacity-50 translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

        <div class="max-w-md w-full relative z-10 bg-white p-10 rounded-[3rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] border border-pink-50 transition-all duration-500 hover:shadow-2xl">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-pink-50 text-[#FF6B6B] mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                </div>
                <h2 class="text-3xl font-black text-[#2E2E2E] mb-2">¿Olvidaste tu contraseña?</h2>
                <p class="text-gray-500">Te enviaremos un correo con las instrucciones para restablecerla.</p>
            </div>

            <div id="auth-alert" class="hidden mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300"></div>

            <form id="forgot-password-form" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-bold text-gray-700 mb-2">Correo Electrónico</label>
                    <input type="email" id="email" required class="w-full px-5 py-3 rounded-2xl border border-gray-200 focus:border-[#FF6B6B] focus:ring-2 focus:ring-pink-100 outline-none transition-all duration-300 text-black" placeholder="tu@email.com" />
                </div>

                <button type="submit" id="submit-btn" class="w-full bg-[#FF6B6B] hover:bg-[#e65c5c] text-white font-bold py-3.5 px-6 rounded-2xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 flex justify-center items-center gap-2">
                    <span>Enviar Correo</span>
                    <span id="spinner" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                </button>
            </form>

            <p class="mt-8 text-center text-sm text-gray-600">
                <a href="/login" class="font-bold text-gray-400 hover:text-[#FF6B6B] transition-colors flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Volver al inicio de sesión
                </a>
            </p>
        </div>
    </main>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    const form = document.getElementById("forgot-password-form") as HTMLFormElement;
    const alertBox = document.getElementById("auth-alert");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const spinner = document.getElementById("spinner");
    const btnText = submitBtn.querySelector("span");

    const showAlert = (message: string, isError: boolean = true) => {
        if (!alertBox) return;
        alertBox.textContent = message;
        alertBox.className = `mb-6 p-4 rounded-xl text-sm font-medium transition-all duration-300 block ${isError ? "bg-red-50 text-red-600 border border-red-100" : "bg-green-50 text-green-600 border border-green-100"}`;
    };

    const setLoading = (loading: boolean) => {
        submitBtn.disabled = loading;
        if (loading) {
            spinner?.classList.remove("hidden");
            if (btnText) btnText.textContent = "Enviando...";
        } else {
            spinner?.classList.add("hidden");
            if (btnText) btnText.textContent = "Enviar Correo";
        }
    };

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = (document.getElementById("email") as HTMLInputElement).value;

        setLoading(true);
        if (alertBox) alertBox.classList.add("hidden");

        try {
            const { error } = await supabase.auth.resetPasswordForEmail(email, {
                redirectTo: `${window.location.origin}/reset-password`,
            });

            if (error) throw error;

            showAlert("Si el correo está registrado, recibirás un enlace de recuperación pronto.", false);
            form.reset();
        } catch (error: any) {
            showAlert(error.message || "Error al enviar el correo");
        } finally {
            setLoading(false);
        }
    });
</script>
