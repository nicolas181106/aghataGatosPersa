---
import Layout from "../../layouts/Layout.astro";
import { gatosChinchilla } from "@/scripts/gatos-chinchilla.js";

/*export function getStaticPaths() {
  return gatosChinchilla.map((gato) => ({
    params: { slugChinchilla: gato.slugChinchilla },
    props: { gato },
  }));
}*/

const { slugChinchilla } = Astro.params;
const gato = gatosChinchilla.find((g) => g.slugChinchilla === slugChinchilla);

if (!gato) {
  throw new Error(`Gato no encontrado: ${slugChinchilla}`);
}
---

<Layout
  title={`${gato.name} | Gato persa chinchilla en Sevilla | Ágatha Gatos Persas`}
  description={`Conoce a ${gato.name}, un gato persa chinchilla criado en un entorno familiar en Sevilla. Descubre su carácter, edad y cómo adoptarlo.`}
>
  <main class="bg-white/90 text-[#2E2E2E] min-h-screen pb-10">
    <section class="bg-gradient-to-r from-[#FF6B6B] via-[#ff9f9f] to-[#FFC3C3] text-white h-40 mt-20 flex items-center justify-center">
      <h1 class="text-4xl font-bold text-white text-center">
        {gato.name}
      </h1>
    </section>
    <section
      aria-label="Perfil de gato"
      class="max-w-5xl mx-auto mt-16 px-4 sm:px-8"
    >
      <article class="bg-white/90 backdrop-blur rounded-3xl shadow-xl border border-[#ffeaea] p-6 sm:p-10 flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/2 flex justify-center">
          <img
            src={gato.img2}
            alt={gato.name}
            class="w-64 h-64 sm:w-80 sm:h-80 rounded-3xl object-cover ring-4 ring-[#FF6B6B] shadow-lg"
          />
        </div>

        <div class="w-full md:w-1/2 space-y-4">
          <header>
            <p class="text-xs font-semibold tracking-[0.25em] uppercase text-[#FF6B6B] mb-2">
              Gatito disponible · Persa {gato.raza}
            </p>
            <h2 class="text-3xl font-bold text-[#2E2E2E] mb-1">{gato.name}</h2>
          </header>

          <dl class="space-y-2 text-sm text-gray-700">
            <div class="flex items-center gap-2">
              <span class="text-lg">📅</span>
              <dt class="font-semibold text-[#FF6B6B]">Edad:</dt>
              <dd class="edad-gatito" data-nacimiento={gato.birth.toString()}></dd>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-lg">{gato.gender === 'Macho' || gato.gender === 'Masculino' ? '💈' : '🎀'}</span>
              <dt class="font-semibold text-[#FF6B6B]">Género:</dt>
              <dd>{gato.gender}</dd>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-lg">🐾</span>
              <dt class="font-semibold text-[#FF6B6B]">Raza:</dt>
              <dd>Persa {gato.raza}</dd>
            </div>
          </dl>

          <p class="text-sm sm:text-base text-gray-700 leading-relaxed">
            {gato.text}
          </p>

          <div class="pt-2 flex flex-col sm:flex-row gap-3">
            <a
              href="/principal/contacto"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#FF6B6B] hover:bg-[#e65c5c] text-white text-sm font-semibold px-6 py-3 shadow-md transition-colors"
            >
              ❤️ Pedir información
            </a>
            <a
              href={`/persa-${gato.raza}`}
              class="inline-flex items-center justify-center gap-2 rounded-full border border-[#FF6B6B] text-[#FF6B6B] text-sm font-medium px-6 py-3 hover:bg-[#FF6B6B] hover:text-white transition-colors"
            >
              ← Volver
            </a>
          </div>
        </div>
      </article>
    </section>
    <script src="../../scripts/edad.js"></script>
  </main>
</Layout>
